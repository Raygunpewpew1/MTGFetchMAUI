<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:AetherVault.Controls"
             xmlns:vm="clr-namespace:AetherVault.ViewModels"
             xmlns:pages="clr-namespace:AetherVault.Pages"
             xmlns:fa="clr-namespace:UraniumUI.Icons.FontAwesome;assembly=UraniumUI.Icons.FontAwesome"
             x:Class="AetherVault.Views.DeckMainTabView"
             x:DataType="vm:DeckDetailViewModel">
    <CollectionView ItemsSource="{Binding FilteredMainDeckGroups}"
                    IsGrouped="True"
                    SelectionMode="None">
        <CollectionView.GroupHeaderTemplate>
            <DataTemplate x:DataType="vm:DeckCardGroup">
                <Label Text="{Binding HeaderText}"
                       FontSize="13"
                       FontAttributes="Bold"
                       TextColor="{StaticResource TextSecondary}"
                       BackgroundColor="{StaticResource Background}"
                       Padding="12,8,12,4" />
            </DataTemplate>
        </CollectionView.GroupHeaderTemplate>
        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="vm:DeckCardDisplayItem">
                <SwipeView>
                    <SwipeView.LeftItems>
                        <SwipeItems>
                            <SwipeItem Text="Side"
                                       BackgroundColor="{StaticResource Primary}"
                                       Command="{Binding Source={RelativeSource AncestorType={x:Type pages:DeckDetailPage}}, Path=BindingContext.MoveCardRowToSideboardCommand}"
                                       CommandParameter="{Binding .}" />
                        </SwipeItems>
                    </SwipeView.LeftItems>
                    <SwipeView.RightItems>
                        <SwipeItems>
                            <SwipeItem Text="Remove"
                                       BackgroundColor="#B00020"
                                       Command="{Binding Source={RelativeSource AncestorType={x:Type pages:DeckDetailPage}}, Path=BindingContext.RemoveCardCommand}"
                                       CommandParameter="{Binding .}" />
                        </SwipeItems>
                    </SwipeView.RightItems>
                    <Border Margin="12,5"
                            Padding="12,10"
                            MinimumHeightRequest="52"
                            BackgroundColor="{Binding StripBackgroundColor}"
                            StrokeShape="RoundRectangle 8"
                            Stroke="Transparent"
                            StrokeThickness="0">
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                <Setter Property="Stroke" Value="{StaticResource Accent}" />
                                <Setter Property="StrokeThickness" Value="2" />
                            </DataTrigger>
                        </Border.Triggers>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type pages:DeckDetailPage}}, Path=BindingContext.DeckListItemTappedCommand}"
                                                 CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto"
                              ColumnSpacing="10"
                              RowDefinitions="Auto,Auto"
                              VerticalOptions="Center">
                            <VerticalStackLayout Grid.Row="0"
                                                 Grid.Column="0"
                                                 Grid.ColumnSpan="5"
                                                 Spacing="2"
                                                 VerticalOptions="Center">
                                <Label Text="{Binding DisplayName}"
                                       TextColor="{StaticResource TextPrimary}"
                                       FontSize="15"
                                       LineBreakMode="TailTruncation" />
                                <HorizontalStackLayout Spacing="8">
                                    <Label Text="{Binding CardTypeText}"
                                           FontSize="11"
                                           TextColor="{StaticResource TextSecondary}"
                                           LineBreakMode="TailTruncation"
                                           HorizontalOptions="Start" />
                                    <Label Text="{Binding OwnedShortText}"
                                           FontSize="11"
                                           TextColor="{StaticResource TextSecondary}">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label" Binding="{Binding IsOverCollection}" Value="True">
                                                <Setter Property="TextColor" Value="#FFB74D" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                </HorizontalStackLayout>
                            </VerticalStackLayout>
                            <controls:ManaCostView Grid.Row="1"
                                                   Grid.Column="0"
                                                   ManaText="{Binding ManaCostText}"
                                                   SymbolSize="14"
                                                   VerticalOptions="Center" />
                            <Border Grid.Row="1"
                                    Grid.Column="1"
                                    BackgroundColor="{StaticResource Surface}"
                                    Padding="8,4"
                                    StrokeShape="RoundRectangle 8"
                                    Stroke="Transparent"
                                    VerticalOptions="Center"
                                    MinimumWidthRequest="28">
                                <Label Text="{Binding DeckQtyLabel}"
                                       TextColor="{StaticResource TextPrimary}"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       HorizontalOptions="Center" />
                            </Border>
                            <Button Grid.Row="1"
                                    Grid.Column="2"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type pages:DeckDetailPage}}, Path=BindingContext.DecrementCardCommand}"
                                    CommandParameter="{Binding .}"
                                    BackgroundColor="{StaticResource Surface}"
                                    TextColor="{StaticResource TextPrimary}"
                                    WidthRequest="40"
                                    HeightRequest="40"
                                    Padding="0"
                                    CornerRadius="8">
                                <Button.ImageSource>
                                    <FontImageSource FontFamily="FASolid"
                                                     Glyph="{x:Static fa:Solid.Minus}"
                                                     Size="14"
                                                     Color="{StaticResource TextPrimary}" />
                                </Button.ImageSource>
                            </Button>
                            <Button Grid.Row="1"
                                    Grid.Column="3"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type pages:DeckDetailPage}}, Path=BindingContext.IncrementCardCommand}"
                                    CommandParameter="{Binding .}"
                                    BackgroundColor="{StaticResource Accent}"
                                    TextColor="Black"
                                    WidthRequest="40"
                                    HeightRequest="40"
                                    Padding="0"
                                    CornerRadius="8">
                                <Button.ImageSource>
                                    <FontImageSource FontFamily="FASolid"
                                                     Glyph="{x:Static fa:Solid.Plus}"
                                                     Size="14"
                                                     Color="Black" />
                                </Button.ImageSource>
                            </Button>
                        </Grid>
                    </Border>
                </SwipeView>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>
</ContentView>
