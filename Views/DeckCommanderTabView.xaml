<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:AetherVault.Controls"
             xmlns:vm="clr-namespace:AetherVault.ViewModels"
             xmlns:pages="clr-namespace:AetherVault.Pages"
             xmlns:fa="clr-namespace:UraniumUI.Icons.FontAwesome;assembly=UraniumUI.Icons.FontAwesome"
             x:Class="AetherVault.Views.DeckCommanderTabView"
             x:DataType="vm:DeckDetailViewModel">
    <ScrollView Padding="16,8">
        <VerticalStackLayout Spacing="12">
            <!-- No commander placeholder -->
            <VerticalStackLayout IsVisible="{Binding HasNoCommander}"
                                 VerticalOptions="Center"
                                 HorizontalOptions="Center"
                                 Spacing="12"
                                 Padding="24,48">
                <Label FontFamily="FASolid"
                       Text="{x:Static fa:Solid.Crown}"
                       FontSize="40"
                       TextColor="{StaticResource TextSecondary}"
                       HorizontalOptions="Center"
                       Opacity="0.6" />
                <Label Text="No commander set"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}"
                       HorizontalOptions="Center" />
                <Label Text="Tap the + button to search and add a legendary creature as your commander."
                       FontSize="14"
                       TextColor="{StaticResource TextSecondary}"
                       HorizontalOptions="Center"
                       HorizontalTextAlignment="Center"
                       MaxLines="3" />
            </VerticalStackLayout>

            <!-- Commander: single full-size card -->
            <Grid IsVisible="{Binding HasNoCommander, Converter={StaticResource InvertedBool}}"
                  HorizontalOptions="Start"
                  Margin="0,0,0,12">
                <Grid.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding ShowCardQuickDetailCommand}"
                                          CommandParameter="{Binding FirstCommander}" />
                </Grid.GestureRecognizers>
                <Border WidthRequest="220"
                        HeightRequest="308"
                        BackgroundColor="{StaticResource Surface}"
                        StrokeShape="RoundRectangle 8"
                        Stroke="{StaticResource CardBackground}"
                        StrokeThickness="1">
                    <controls:CachedCardImage CardUuid="{Binding FirstCommander.ImageId}"
                                               ImageSize="large"
                                               HorizontalOptions="Fill"
                                               VerticalOptions="Fill" />
                </Border>
                <Button x:Name="CommanderMenuButton"
                        HorizontalOptions="Start"
                        VerticalOptions="Start"
                        Margin="8"
                        WidthRequest="36"
                        HeightRequest="36"
                        CornerRadius="18"
                        BackgroundColor="#CC000000"
                        Padding="0"
                        Clicked="OnCommanderMenuClicked">
                    <Button.ImageSource>
                        <FontImageSource FontFamily="FASolid"
                                         Glyph="{x:Static fa:Solid.EllipsisVertical}"
                                         Size="16"
                                         Color="White" />
                    </Button.ImageSource>
                </Button>
            </Grid>

            <!-- Additional commander cards (e.g. partner) -->
            <CollectionView IsVisible="{Binding HasMultipleCommanders}"
                            ItemsSource="{Binding AdditionalCommanderCards}"
                            SelectionMode="None">
                <CollectionView.Header>
                    <Label Text="Partner / other"
                           FontSize="12"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextSecondary}"
                           Padding="0,8,0,4" />
                </CollectionView.Header>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:DeckCardDisplayItem">
                        <SwipeView>
                            <SwipeView.RightItems>
                                <SwipeItems>
                                    <SwipeItem Text="Remove"
                                               BackgroundColor="#B00020"
                                               Command="{Binding Source={RelativeSource AncestorType={x:Type pages:DeckDetailPage}}, Path=BindingContext.RemoveCardCommand}"
                                               CommandParameter="{Binding .}" />
                                </SwipeItems>
                            </SwipeView.RightItems>
                            <Border Style="{StaticResource CardStyle}"
                                    Margin="0,6"
                                    Padding="12,10"
                                    MinimumHeightRequest="48">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type pages:DeckDetailPage}}, Path=BindingContext.ShowCardQuickDetailCommand}"
                                                         CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <Grid ColumnDefinitions="Auto,Auto,*"
                                      ColumnSpacing="10"
                                      VerticalOptions="Center">
                                    <Border Grid.Column="0"
                                            WidthRequest="36"
                                            HeightRequest="50"
                                            BackgroundColor="{StaticResource Surface}"
                                            StrokeShape="RoundRectangle 4"
                                            Stroke="Transparent"
                                            VerticalOptions="Center">
                                        <controls:CachedCardImage CardUuid="{Binding ImageId}"
                                                                   HorizontalOptions="Fill"
                                                                   VerticalOptions="Fill" />
                                    </Border>
                                    <Border Grid.Column="1"
                                            BackgroundColor="{StaticResource Accent}"
                                            Padding="6,4"
                                            StrokeShape="RoundRectangle 8"
                                            Stroke="Transparent"
                                            VerticalOptions="Center"
                                            MinimumWidthRequest="28">
                                        <Label Text="{Binding DeckQtyLabel}"
                                               TextColor="Black"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               HorizontalOptions="Center" />
                                    </Border>
                                    <VerticalStackLayout Grid.Column="2"
                                                         Spacing="2"
                                                         VerticalOptions="Center">
                                        <Label Text="{Binding DisplayName}"
                                               TextColor="{StaticResource TextPrimary}"
                                               FontSize="14"
                                               LineBreakMode="TailTruncation" />
                                        <Label Text="{Binding CardTypeText}"
                                               TextColor="{StaticResource TextSecondary}"
                                               FontSize="11"
                                               LineBreakMode="TailTruncation" />
                                        <Label Text="{Binding OwnedShortText}"
                                               FontSize="11"
                                               TextColor="{StaticResource TextSecondary}">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding IsOverCollection}" Value="True">
                                                    <Setter Property="TextColor" Value="#FFB74D" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentView>
