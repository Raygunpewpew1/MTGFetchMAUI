<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:fa="clr-namespace:UraniumUI.Icons.FontAwesome;assembly=UraniumUI.Icons.FontAwesome"
             xmlns:vm="clr-namespace:AetherVault.ViewModels"
             xmlns:models="clr-namespace:AetherVault.Models"
             xmlns:controls="clr-namespace:AetherVault.Controls"
             x:Class="AetherVault.Pages.DecksPage"
             Title="Decks"
             BackgroundColor="{StaticResource Background}"
             x:DataType="vm:DecksViewModel">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Header: title and status -->
        <Border Grid.Row="0"
                Style="{StaticResource CardStyle}"
                Margin="16,12,16,8"
                Padding="16,12">
            <VerticalStackLayout Spacing="4">
                <Label Text="My Decks"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}" />
                <HorizontalStackLayout Spacing="8" VerticalOptions="Center">
                    <ActivityIndicator IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}"
                                       HeightRequest="16"
                                       WidthRequest="16"
                                       Color="{StaticResource Accent}" />
                    <Label Text="{Binding StatusDisplayText}"
                           FontSize="13"
                           TextColor="{Binding StatusTextColor}"
                           VerticalOptions="Center" />
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </Border>

        <!-- Primary CTA + import/export actions -->
        <VerticalStackLayout Grid.Row="1"
                             Margin="16,0,16,12"
                             Spacing="10">
            <Button Clicked="OnNewDeckClicked"
                    Text="New deck"
                    BackgroundColor="{StaticResource Accent}"
                    TextColor="Black"
                    FontSize="17"
                    FontAttributes="Bold"
                    CornerRadius="12"
                    HeightRequest="52"
                    HorizontalOptions="Fill"
                    BorderWidth="0">
                <Button.ImageSource>
                    <FontImageSource FontFamily="FASolid"
                                     Glyph="{x:Static fa:Solid.Plus}"
                                     Size="18"
                                     Color="Black" />
                </Button.ImageSource>
            </Button>

            <Grid ColumnDefinitions="*,*"
                  ColumnSpacing="12">
                <Button Grid.Column="0"
                        Command="{Binding ImportDecksCommand}"
                        Text="Import decks"
                        BackgroundColor="{StaticResource Surface}"
                        TextColor="{StaticResource TextPrimary}"
                        FontSize="14"
                        CornerRadius="12"
                        HeightRequest="44"
                        HorizontalOptions="Fill"
                        BorderWidth="0" />
                <Button Grid.Column="1"
                        Command="{Binding ExportDecksCommand}"
                        Text="Export all"
                        BackgroundColor="{StaticResource Surface}"
                        TextColor="{StaticResource TextPrimary}"
                        FontSize="14"
                        CornerRadius="12"
                        HeightRequest="44"
                        HorizontalOptions="Fill"
                        BorderWidth="0" />
            </Grid>
            <Button Clicked="OnBrowseMTGJsonClicked"
                    Text="Browse Decks"
                    BackgroundColor="{StaticResource Surface}"
                    TextColor="{StaticResource TextPrimary}"
                    FontSize="14"
                    CornerRadius="12"
                    HeightRequest="44"
                    HorizontalOptions="Fill"
                    BorderWidth="0" />
        </VerticalStackLayout>

        <!-- Content area -->
        <Grid Grid.Row="2" BackgroundColor="{StaticResource Background}">

            <!-- Deck List -->
            <CollectionView ItemsSource="{Binding Decks}"
                            IsVisible="{Binding IsEmpty, Converter={StaticResource InvertedBool}}"
                            SelectionMode="Single"
                            SelectionChanged="OnDeckSelectionChanged"
                            Margin="0,0,0,8">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:DeckEntity">
                        <Border Style="{StaticResource CardStyle}"
                                Margin="16,6"
                                Padding="16,14"
                                MinimumHeightRequest="72">
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                                <controls:DeckListItem Grid.Row="0"
                                                      Grid.RowSpan="3"
                                                      Grid.Column="0" />
                                <HorizontalStackLayout Grid.Row="0"
                                                       Grid.Column="1"
                                                       Spacing="8"
                                                       VerticalOptions="Center">
                                    <Button Clicked="OnRenameDeckButtonClicked"
                                            BackgroundColor="Transparent"
                                            Padding="8"
                                            HeightRequest="40"
                                            WidthRequest="40"
                                            CommandParameter="{Binding .}">
                                        <Button.ImageSource>
                                            <FontImageSource FontFamily="FASolid"
                                                             Glyph="{x:Static fa:Solid.PenToSquare}"
                                                             Size="16"
                                                             Color="{StaticResource TextSecondary}" />
                                        </Button.ImageSource>
                                    </Button>
                                    <Button Clicked="OnDeleteDeckButtonClicked"
                                            BackgroundColor="Transparent"
                                            Padding="8"
                                            HeightRequest="40"
                                            WidthRequest="40"
                                            CommandParameter="{Binding .}">
                                        <Button.ImageSource>
                                            <FontImageSource FontFamily="FASolid"
                                                             Glyph="{x:Static fa:Solid.TrashCan}"
                                                             Size="16"
                                                             Color="{StaticResource ErrorColor}" />
                                        </Button.ImageSource>
                                    </Button>
                                </HorizontalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Empty state -->
            <controls:EmptyStateView IsVisible="{Binding IsEmpty}"
                                     VerticalOptions="Center"
                                     HorizontalOptions="Center"
                                     Margin="32"
                                     IconGlyph="{x:Static fa:Solid.LayerGroup}"
                                     Message="No decks yet"
                                     SecondaryMessage="Tap &quot;New deck&quot; above to create your first deck, then add cards from Search or your Collection." />
        </Grid>

    </Grid>

</ContentPage>
