<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
               xmlns:controls="clr-namespace:AetherVault.Controls"
               xmlns:models="clr-namespace:AetherVault.Models"
               xmlns:vm="clr-namespace:AetherVault.ViewModels"
               xmlns:pages="clr-namespace:AetherVault.Pages"
               x:Class="AetherVault.Pages.DeckAddCardsSheet"
               x:DataType="vm:DeckDetailViewModel"
               CanBeDismissedByTappingOutsideOfPopup="True"
               HorizontalOptions="Fill"
               VerticalOptions="End"
               BackgroundColor="Transparent">

    <Border x:Name="SheetChrome"
            BackgroundColor="{StaticResource CardBackground}"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 20,20,0,0"
            Margin="0"
            VerticalOptions="End"
            HorizontalOptions="Fill">
        <Border.Shadow>
            <Shadow Brush="Black" Offset="0,-2" Radius="16" Opacity="0.35" />
        </Border.Shadow>

        <!-- Search row first so it sits highest on screen (above the keyboard). Title / Done below. -->
        <Grid x:Name="SheetRootGrid"
              RowDefinitions="Auto,Auto,Auto,Auto,*"
              MinimumHeightRequest="260"
              MaximumHeightRequest="720"
              Padding="0,12,0,20"
              RowSpacing="6">

            <Grid Grid.Row="0"
                  ColumnDefinitions="*,Auto"
                  Padding="16,0,12,0"
                  ColumnSpacing="8">
                <material:TextField Title="Search cards…"
                                    Text="{Binding AddCardSearchText, Mode=TwoWay}"
                                    ReturnCommand="{Binding AddCardSearchCommand}"
                                    BackgroundColor="{StaticResource Surface}"
                                    TextColor="{StaticResource TextPrimary}"
                                    TitleColor="{StaticResource TextSecondary}"
                                    AccentColor="{StaticResource Primary}"
                                    AllowClear="True" />
                <ActivityIndicator Grid.Column="1"
                                   IsRunning="{Binding IsAddCardSearchBusy}"
                                   IsVisible="{Binding IsAddCardSearchBusy}"
                                   HeightRequest="24"
                                   WidthRequest="24"
                                   VerticalOptions="Center"
                                   Color="{StaticResource Primary}" />
            </Grid>

            <Grid Grid.Row="1"
                  ColumnDefinitions="*,Auto"
                  Padding="16,4,12,4"
                  ColumnSpacing="8">
                <Label Text="Add cards"
                       FontSize="17"
                       FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}"
                       VerticalOptions="Center" />
                <Button Grid.Column="1"
                        Text="Done"
                        Clicked="OnDoneClicked"
                        BackgroundColor="{StaticResource Surface}"
                        TextColor="{StaticResource TextPrimary}"
                        CornerRadius="8"
                        Padding="12,6"
                        VerticalOptions="Center" />
            </Grid>

            <Label Grid.Row="2"
                   Text="Adds to the tab you had open (Commander, Main, or Sideboard)."
                   FontSize="11"
                   TextColor="{StaticResource TextSecondary}"
                   LineBreakMode="WordWrap"
                   Padding="16,0,16,0" />

            <Grid Grid.Row="3"
                  ColumnDefinitions="*,Auto"
                  ColumnSpacing="8"
                  Padding="16,4,16,0">
                <Label Text="Only my collection"
                       TextColor="{StaticResource TextSecondary}"
                       FontSize="13"
                       VerticalOptions="Center" />
                <Switch Grid.Column="1"
                        IsToggled="{Binding AddCardSearchOnlyCollection, Mode=TwoWay}"
                        OnColor="{StaticResource Primary}"
                        VerticalOptions="Center" />
            </Grid>

            <Border Grid.Row="4"
                    Stroke="Transparent"
                    StrokeShape="RoundRectangle 4"
                    BackgroundColor="{StaticResource Surface}"
                    Padding="0,4"
                    Margin="16,8,16,0">
                <CollectionView ItemsSource="{Binding AddCardSearchResults}"
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Card">
                            <Grid Padding="12,8" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" BackgroundColor="Transparent">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type pages:DeckAddCardsSheet}}, Path=BindingContext.AddCardFromSearchCommand}"
                                                         CommandParameter="{Binding .}" />
                                </Grid.GestureRecognizers>
                                <Border Grid.Column="0" WidthRequest="36" HeightRequest="50" BackgroundColor="{StaticResource CardBackground}" StrokeShape="RoundRectangle 4" Stroke="Transparent">
                                    <controls:CachedCardImage CardUuid="{Binding ImageId}" HorizontalOptions="Fill" VerticalOptions="Fill" />
                                </Border>
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="{Binding Name}" TextColor="{StaticResource TextPrimary}" FontSize="14" FontAttributes="Bold" LineBreakMode="TailTruncation" />
                                    <Label Text="{Binding CardType}" TextColor="{StaticResource TextSecondary}" FontSize="11" LineBreakMode="TailTruncation" />
                                </VerticalStackLayout>
                                <controls:ManaCostView Grid.Column="2" ManaText="{Binding ManaCost}" SymbolSize="12" VerticalOptions="Center" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Border>
        </Grid>
    </Border>
</toolkit:Popup>
