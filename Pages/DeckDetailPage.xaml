<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             xmlns:controls="clr-namespace:AetherVault.Controls"
             xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
             xmlns:models="clr-namespace:AetherVault.Models"
             xmlns:vm="clr-namespace:AetherVault.ViewModels"
             xmlns:pages="clr-namespace:AetherVault.Pages"
             xmlns:views="clr-namespace:AetherVault.Views"
             xmlns:fa="clr-namespace:UraniumUI.Icons.FontAwesome;assembly=UraniumUI.Icons.FontAwesome"
             x:Class="AetherVault.Pages.DeckDetailPage"
             Title="{Binding Deck.Name}"
             BackgroundColor="{StaticResource Background}"
             x:DataType="vm:DeckDetailViewModel">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Select"
                     Command="{Binding ToggleSelectionModeCommand}"
                     Order="Primary"
                     Priority="0" />
        <ToolbarItem Text="Import"
                     Clicked="OnImportCsvClicked"
                     Order="Primary"
                     Priority="1" />
        <ToolbarItem Text="Export"
                     Clicked="OnExportDeckClicked"
                     Order="Primary"
                     Priority="2" />
    </ContentPage.ToolbarItems>

    <Grid x:Name="DeckDetailRoot" RowDefinitions="100,Auto,Auto,Auto,*,Auto">

        <!-- Row 0: Commander Art Header (gradient, shows commander name) -->
        <skia:SKCanvasView Grid.Row="0"
                           x:Name="CommanderArtCanvas"
                           HeightRequest="100"
                           PaintSurface="OnCommanderArtPaint" />

        <!-- Row 1: Section Tab Bar (icons + labels for easier tapping) -->
        <Grid Grid.Row="1"
              ColumnDefinitions="*,*,*,*"
              BackgroundColor="{StaticResource Surface}"
              HeightRequest="52"
              ColumnSpacing="0">
            <Border Grid.Column="0" StrokeThickness="0" Padding="4,8">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SelectCommanderCommand}" />
                </Border.GestureRecognizers>
                <VerticalStackLayout Spacing="2" HorizontalOptions="Center" VerticalOptions="Center">
                    <Label FontFamily="FASolid" Text="{x:Static fa:Solid.Crown}" FontSize="14" TextColor="{Binding Tab0Color}" HorizontalOptions="Center" />
                    <Label Text="Commander" FontSize="11" FontAttributes="{Binding Tab0Font}" TextColor="{Binding Tab0Color}" HorizontalOptions="Center" />
                    <BoxView HeightRequest="2" Color="{Binding Tab0Color}" Opacity="{Binding Tab0Indicator}" HorizontalOptions="Fill" />
                </VerticalStackLayout>
            </Border>
            <Border Grid.Column="1" StrokeThickness="0" Padding="4,8">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SelectMainCommand}" />
                </Border.GestureRecognizers>
                <VerticalStackLayout Spacing="2" HorizontalOptions="Center" VerticalOptions="Center">
                    <Label FontFamily="FASolid" Text="{x:Static fa:Solid.List}" FontSize="14" TextColor="{Binding Tab1Color}" HorizontalOptions="Center" />
                    <Label Text="Main" FontSize="11" FontAttributes="{Binding Tab1Font}" TextColor="{Binding Tab1Color}" HorizontalOptions="Center" />
                    <BoxView HeightRequest="2" Color="{Binding Tab1Color}" Opacity="{Binding Tab1Indicator}" HorizontalOptions="Fill" />
                </VerticalStackLayout>
            </Border>
            <Border Grid.Column="2" StrokeThickness="0" Padding="4,8">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SelectSideboardCommand}" />
                </Border.GestureRecognizers>
                <VerticalStackLayout Spacing="2" HorizontalOptions="Center" VerticalOptions="Center">
                    <Label FontFamily="FASolid" Text="{x:Static fa:Solid.LayerGroup}" FontSize="14" TextColor="{Binding Tab2Color}" HorizontalOptions="Center" />
                    <Label Text="Sideboard" FontSize="11" FontAttributes="{Binding Tab2Font}" TextColor="{Binding Tab2Color}" HorizontalOptions="Center" />
                    <BoxView HeightRequest="2" Color="{Binding Tab2Color}" Opacity="{Binding Tab2Indicator}" HorizontalOptions="Fill" />
                </VerticalStackLayout>
            </Border>
            <Border Grid.Column="3" StrokeThickness="0" Padding="4,8">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SelectStatsCommand}" />
                </Border.GestureRecognizers>
                <VerticalStackLayout Spacing="2" HorizontalOptions="Center" VerticalOptions="Center">
                    <Label FontFamily="FASolid" Text="{x:Static fa:Solid.ChartColumn}" FontSize="14" TextColor="{Binding Tab3Color}" HorizontalOptions="Center" />
                    <Label Text="Stats" FontSize="11" FontAttributes="{Binding Tab3Font}" TextColor="{Binding Tab3Color}" HorizontalOptions="Center" />
                    <BoxView HeightRequest="2" Color="{Binding Tab3Color}" Opacity="{Binding Tab3Indicator}" HorizontalOptions="Fill" />
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- Row 2: Bulk edit toolbar (Main / Sideboard / Commander lists) -->
        <Border Grid.Row="2"
                Padding="8,6"
                BackgroundColor="{StaticResource Surface}"
                StrokeThickness="0"
                IsVisible="{Binding IsSelectionMode}">
            <ScrollView Orientation="Horizontal"
                        HorizontalScrollBarVisibility="Never">
                <HorizontalStackLayout Spacing="6"
                                       VerticalOptions="Center">
                    <Button Text="All"
                            Command="{Binding SelectAllInCurrentSectionCommand}"
                            Padding="10,6"
                            FontSize="12"
                            BackgroundColor="{StaticResource CardBackground}"
                            TextColor="{StaticResource TextPrimary}" />
                    <Button Text="None"
                            Command="{Binding ClearDeckSelectionCommand}"
                            Padding="10,6"
                            FontSize="12"
                            BackgroundColor="{StaticResource CardBackground}"
                            TextColor="{StaticResource TextPrimary}" />
                    <Button Text="-1"
                            Command="{Binding BulkDecrementSelectionCommand}"
                            Padding="10,6"
                            FontSize="12"
                            BackgroundColor="{StaticResource CardBackground}"
                            TextColor="{StaticResource TextPrimary}" />
                    <Button Text="+1"
                            Command="{Binding BulkIncrementSelectionCommand}"
                            Padding="10,6"
                            FontSize="12"
                            BackgroundColor="{StaticResource Accent}"
                            TextColor="Black" />
                    <Button Text="To Main"
                            Command="{Binding BulkMoveSelectionToMainCommand}"
                            IsVisible="{Binding IsSideboardTab}"
                            Padding="10,6"
                            FontSize="12"
                            BackgroundColor="{StaticResource CardBackground}"
                            TextColor="{StaticResource TextPrimary}" />
                    <Button Text="To Side"
                            Command="{Binding BulkMoveSelectionToSideboardCommand}"
                            IsVisible="{Binding IsMainTab}"
                            Padding="10,6"
                            FontSize="12"
                            BackgroundColor="{StaticResource CardBackground}"
                            TextColor="{StaticResource TextPrimary}" />
                    <Button Text="Remove"
                            Command="{Binding BulkRemoveSelectionCommand}"
                            Padding="10,6"
                            FontSize="12"
                            BackgroundColor="#B00020"
                            TextColor="White" />
                    <Button Text="Done"
                            Command="{Binding ToggleSelectionModeCommand}"
                            Padding="10,6"
                            FontSize="12"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="White" />
                </HorizontalStackLayout>
            </ScrollView>
        </Border>

        <!-- Row 3: Quick find cards already in this deck -->
        <Border Grid.Row="3"
                Padding="12,6"
                BackgroundColor="{StaticResource Background}"
                StrokeThickness="0"
                IsVisible="{Binding IsStatsTab, Converter={StaticResource InvertedBool}}">
            <material:TextField Title="Find in deck…"
                                Text="{Binding DeckListFilterText, Mode=TwoWay}"
                                BackgroundColor="{StaticResource Surface}"
                                TextColor="{StaticResource TextPrimary}"
                                TitleColor="{StaticResource TextSecondary}"
                                AccentColor="{StaticResource Primary}"
                                AllowClear="True" />
        </Border>

        <!-- Row 4: Tab content + floating add button -->
        <Grid Grid.Row="4">
            <views:DeckCommanderTabView x:Name="CommanderTabView"
                                         IsVisible="{Binding IsCommanderTab}" />
            <views:DeckMainTabView IsVisible="{Binding IsMainTab}" />
            <views:DeckSideboardTabView IsVisible="{Binding IsSideboardTab}" />
            <views:DeckStatsTabView IsVisible="{Binding IsStatsTab}" />

            <Button Clicked="OnAddCardsClicked"
                    HorizontalOptions="End"
                    VerticalOptions="End"
                    Margin="0,0,20,20"
                    WidthRequest="56"
                    HeightRequest="56"
                    CornerRadius="28"
                    BackgroundColor="{StaticResource Accent}"
                    TextColor="Black"
                    FontSize="28"
                    Padding="0"
                    LineBreakMode="NoWrap"
                    ZIndex="100"
                    IsVisible="{Binding IsStatsTab, Converter={StaticResource InvertedBool}}"
                    SemanticProperties.Hint="Search and add cards to this deck"
                    Text="+"
                    FontAttributes="Bold" />
        </Grid>

        <!-- Row 5: Deck summary bar + status -->
        <Grid Grid.Row="5"
              RowDefinitions="Auto,Auto"
              Padding="12,8"
              BackgroundColor="{StaticResource Primary}"
              RowSpacing="4">
            <Label Grid.Row="0"
                   Text="{Binding DeckSummaryText}"
                   FontSize="14"
                   FontAttributes="Bold"
                   TextColor="White"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />
            <Label Grid.Row="1"
                   Text="{Binding StatusDisplayText}"
                   FontSize="12"
                   TextColor="{Binding StatusTextColor}"
                   HorizontalOptions="Center"
                   VerticalOptions="Center"
                   Opacity="0.9" />
        </Grid>

    </Grid>

</ContentPage>
