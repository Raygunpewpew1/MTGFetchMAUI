<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             xmlns:controls="clr-namespace:AetherVault.Controls"
             xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
             xmlns:models="clr-namespace:AetherVault.Models"
             xmlns:vm="clr-namespace:AetherVault.ViewModels"
             xmlns:pages="clr-namespace:AetherVault.Pages"
             xmlns:fa="clr-namespace:UraniumUI.Icons.FontAwesome;assembly=UraniumUI.Icons.FontAwesome"
             x:Class="AetherVault.Pages.DeckDetailPage"
             Title="{Binding Deck.Name}"
             BackgroundColor="{StaticResource Background}"
             x:DataType="vm:DeckDetailViewModel">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Export"
                     Clicked="OnExportDeckClicked" />
    </ContentPage.ToolbarItems>

    <Grid x:Name="DeckDetailRoot" RowDefinitions="Auto,100,Auto,Auto,*,Auto">

        <!-- Row 0: Deck header -->
        <Border Grid.Row="0"
                Style="{StaticResource CardStyle}"
                Margin="16,12,16,8"
                Padding="16,12">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="16">
                <VerticalStackLayout Spacing="4" VerticalOptions="Center">
                    <Label Text="{Binding Deck.Name}"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}"
                           LineBreakMode="TailTruncation" />
                    <Label Text="{Binding DeckFormat}"
                           FontSize="13"
                           TextColor="{StaticResource TextSecondary}" />
                </VerticalStackLayout>

                <Border Grid.Column="1"
                        BackgroundColor="{StaticResource Accent}"
                        Padding="14,8"
                        StrokeShape="RoundRectangle 12"
                        Stroke="Transparent"
                        VerticalOptions="Center">
                    <Label Text="{Binding TotalCardCount}"
                           TextColor="Black"
                           FontSize="16"
                           FontAttributes="Bold" />
                </Border>
            </Grid>
        </Border>

        <!-- Row 1: Commander Art Header (gradient, shows commander name) -->
        <skia:SKCanvasView Grid.Row="1"
                           x:Name="CommanderArtCanvas"
                           HeightRequest="100"
                           PaintSurface="OnCommanderArtPaint" />

        <!-- Row 2: Section Tab Bar (icons + labels for easier tapping) -->
        <Grid Grid.Row="2"
              ColumnDefinitions="*,*,*,*"
              BackgroundColor="{StaticResource Surface}"
              HeightRequest="52"
              ColumnSpacing="0">
            <Border Grid.Column="0" StrokeThickness="0" Padding="4,8">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SelectCommanderCommand}" />
                </Border.GestureRecognizers>
                <VerticalStackLayout Spacing="2" HorizontalOptions="Center" VerticalOptions="Center">
                    <Label FontFamily="FASolid" Text="{x:Static fa:Solid.Crown}" FontSize="14" TextColor="{Binding Tab0Color}" HorizontalOptions="Center" />
                    <Label Text="Commander" FontSize="11" FontAttributes="{Binding Tab0Font}" TextColor="{Binding Tab0Color}" HorizontalOptions="Center" />
                    <BoxView HeightRequest="2" Color="{Binding Tab0Color}" Opacity="{Binding Tab0Indicator}" HorizontalOptions="Fill" />
                </VerticalStackLayout>
            </Border>
            <Border Grid.Column="1" StrokeThickness="0" Padding="4,8">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SelectMainCommand}" />
                </Border.GestureRecognizers>
                <VerticalStackLayout Spacing="2" HorizontalOptions="Center" VerticalOptions="Center">
                    <Label FontFamily="FASolid" Text="{x:Static fa:Solid.List}" FontSize="14" TextColor="{Binding Tab1Color}" HorizontalOptions="Center" />
                    <Label Text="Main" FontSize="11" FontAttributes="{Binding Tab1Font}" TextColor="{Binding Tab1Color}" HorizontalOptions="Center" />
                    <BoxView HeightRequest="2" Color="{Binding Tab1Color}" Opacity="{Binding Tab1Indicator}" HorizontalOptions="Fill" />
                </VerticalStackLayout>
            </Border>
            <Border Grid.Column="2" StrokeThickness="0" Padding="4,8">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SelectSideboardCommand}" />
                </Border.GestureRecognizers>
                <VerticalStackLayout Spacing="2" HorizontalOptions="Center" VerticalOptions="Center">
                    <Label FontFamily="FASolid" Text="{x:Static fa:Solid.LayerGroup}" FontSize="14" TextColor="{Binding Tab2Color}" HorizontalOptions="Center" />
                    <Label Text="Sideboard" FontSize="11" FontAttributes="{Binding Tab2Font}" TextColor="{Binding Tab2Color}" HorizontalOptions="Center" />
                    <BoxView HeightRequest="2" Color="{Binding Tab2Color}" Opacity="{Binding Tab2Indicator}" HorizontalOptions="Fill" />
                </VerticalStackLayout>
            </Border>
            <Border Grid.Column="3" StrokeThickness="0" Padding="4,8">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding SelectStatsCommand}" />
                </Border.GestureRecognizers>
                <VerticalStackLayout Spacing="2" HorizontalOptions="Center" VerticalOptions="Center">
                    <Label FontFamily="FASolid" Text="{x:Static fa:Solid.ChartColumn}" FontSize="14" TextColor="{Binding Tab3Color}" HorizontalOptions="Center" />
                    <Label Text="Stats" FontSize="11" FontAttributes="{Binding Tab3Font}" TextColor="{Binding Tab3Color}" HorizontalOptions="Center" />
                    <BoxView HeightRequest="2" Color="{Binding Tab3Color}" Opacity="{Binding Tab3Indicator}" HorizontalOptions="Fill" />
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!-- Row 3: Inline add-card search (visible on Commander, Main, Sideboard tabs) -->
        <VerticalStackLayout Grid.Row="3"
                            IsVisible="{Binding IsAddCardSearchVisible}"
                            Spacing="4"
                            Padding="12,8,12,8"
                            BackgroundColor="{StaticResource Background}">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <material:TextField Title="Search to add card…"
                                    Text="{Binding AddCardSearchText, Mode=TwoWay}"
                                    ReturnCommand="{Binding AddCardSearchCommand}"
                                    BackgroundColor="{StaticResource Surface}"
                                    TextColor="{StaticResource TextPrimary}"
                                    TitleColor="{StaticResource TextSecondary}"
                                    AccentColor="{StaticResource Primary}"
                                    AllowClear="True" />
                <ActivityIndicator Grid.Column="1"
                                   IsRunning="{Binding IsAddCardSearchBusy}"
                                   IsVisible="{Binding IsAddCardSearchBusy}"
                                   HeightRequest="24"
                                   WidthRequest="24"
                                   VerticalOptions="Center"
                                   Color="{StaticResource Primary}" />
            </Grid>
            <Border MaximumHeightRequest="220"
                    Stroke="Transparent"
                    StrokeShape="RoundRectangle 4"
                    BackgroundColor="{StaticResource Surface}"
                    Padding="0,4">
                <CollectionView ItemsSource="{Binding AddCardSearchResults}"
                               SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:Card">
                            <Grid Padding="12,8" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" BackgroundColor="Transparent">
                                <Grid.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type pages:DeckDetailPage}}, Path=BindingContext.AddCardFromSearchCommand}"
                                                         CommandParameter="{Binding .}" />
                                </Grid.GestureRecognizers>
                                <Border Grid.Column="0" WidthRequest="36" HeightRequest="50" BackgroundColor="{StaticResource CardBackground}" StrokeShape="RoundRectangle 4" Stroke="Transparent">
                                    <controls:CachedCardImage CardUuid="{Binding ImageId}" HorizontalOptions="Fill" VerticalOptions="Fill" />
                                </Border>
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                                    <Label Text="{Binding Name}" TextColor="{StaticResource TextPrimary}" FontSize="14" FontAttributes="Bold" LineBreakMode="TailTruncation" />
                                    <Label Text="{Binding CardType}" TextColor="{StaticResource TextSecondary}" FontSize="11" LineBreakMode="TailTruncation" />
                                </VerticalStackLayout>
                                <controls:ManaCostView Grid.Column="2" ManaText="{Binding ManaCost}" SymbolSize="12" VerticalOptions="Center" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Border>
        </VerticalStackLayout>

        <!-- Row 4: Content Panels -->
        <Grid Grid.Row="4">

            <!-- Commander Tab -->
            <ScrollView IsVisible="{Binding IsCommanderTab}" Padding="16,8">
                <VerticalStackLayout Spacing="12">
                    <!-- No commander placeholder -->
                    <VerticalStackLayout IsVisible="{Binding HasNoCommander}"
                                         VerticalOptions="Center"
                                         HorizontalOptions="Center"
                                         Spacing="12"
                                         Padding="24,48">
                        <Label FontFamily="FASolid"
                               Text="{x:Static fa:Solid.Crown}"
                               FontSize="40"
                               TextColor="{StaticResource TextSecondary}"
                               HorizontalOptions="Center"
                               Opacity="0.6" />
                        <Label Text="No commander set"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}"
                               HorizontalOptions="Center" />
                        <Label Text="Search above to add a legendary creature as your commander."
                               FontSize="14"
                               TextColor="{StaticResource TextSecondary}"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"
                               MaxLines="3" />
                    </VerticalStackLayout>

                    <!-- Commander cards -->
                    <CollectionView ItemsSource="{Binding CommanderCards}"
                                    SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="vm:DeckCardDisplayItem">
                                <SwipeView>
                                    <SwipeView.RightItems>
                                        <SwipeItems>
                                            <SwipeItem Text="Remove"
                                                       BackgroundColor="#B00020"
                                                       Command="{Binding Source={RelativeSource AncestorType={x:Type pages:DeckDetailPage}}, Path=BindingContext.RemoveCardCommand}"
                                                       CommandParameter="{Binding .}" />
                                        </SwipeItems>
                                    </SwipeView.RightItems>
                                    <Border Style="{StaticResource CardStyle}"
                                            Margin="0,6"
                                            Padding="12,10"
                                            MinimumHeightRequest="48">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type pages:DeckDetailPage}}, Path=BindingContext.ShowCardQuickDetailCommand}"
                                                                 CommandParameter="{Binding .}" />
                                        </Border.GestureRecognizers>
                                        <Grid ColumnDefinitions="Auto,Auto,*"
                                              ColumnSpacing="10"
                                              VerticalOptions="Center">
                                            <Border Grid.Column="0"
                                                    WidthRequest="36"
                                                    HeightRequest="50"
                                                    BackgroundColor="{StaticResource Surface}"
                                                    StrokeShape="RoundRectangle 4"
                                                    Stroke="Transparent"
                                                    VerticalOptions="Center">
                                                <controls:CachedCardImage CardUuid="{Binding ImageId}"
                                                                         HorizontalOptions="Fill"
                                                                         VerticalOptions="Fill" />
                                            </Border>
                                            <Border Grid.Column="1"
                                                    BackgroundColor="{StaticResource Accent}"
                                                    Padding="6,4"
                                                    StrokeShape="RoundRectangle 8"
                                                    Stroke="Transparent"
                                                    VerticalOptions="Center"
                                                    MinimumWidthRequest="28">
                                                <Label Text="{Binding Entity.Quantity}"
                                                       TextColor="Black"
                                                       FontSize="13"
                                                       FontAttributes="Bold"
                                                       HorizontalOptions="Center" />
                                            </Border>
                                            <VerticalStackLayout Grid.Column="2"
                                                               Spacing="2"
                                                               VerticalOptions="Center">
                                                <Label Text="{Binding DisplayName}"
                                                       TextColor="{StaticResource TextPrimary}"
                                                       FontSize="14"
                                                       LineBreakMode="TailTruncation" />
                                                <Label Text="{Binding CardTypeText}"
                                                       TextColor="{StaticResource TextSecondary}"
                                                       FontSize="11"
                                                       LineBreakMode="TailTruncation" />
                                            </VerticalStackLayout>
                                        </Grid>
                                    </Border>
                                </SwipeView>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </ScrollView>

            <!-- Main Deck Tab -->
            <CollectionView IsVisible="{Binding IsMainTab}"
                            ItemsSource="{Binding MainDeckGroups}"
                            IsGrouped="True"
                            SelectionMode="None">
                <CollectionView.GroupHeaderTemplate>
                    <DataTemplate x:DataType="vm:DeckCardGroup">
                        <Label Text="{Binding GroupName}"
                               FontSize="12"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextSecondary}"
                               BackgroundColor="{StaticResource Background}"
                               Padding="12,6,12,2" />
                    </DataTemplate>
                </CollectionView.GroupHeaderTemplate>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:DeckCardDisplayItem">
                        <SwipeView>
                            <SwipeView.RightItems>
                                <SwipeItems>
                                    <SwipeItem Text="Remove"
                                               BackgroundColor="#B00020"
                                               Command="{Binding Source={RelativeSource AncestorType={x:Type pages:DeckDetailPage}}, Path=BindingContext.RemoveCardCommand}"
                                               CommandParameter="{Binding .}" />
                                </SwipeItems>
                            </SwipeView.RightItems>
                            <Border Style="{StaticResource CardStyle}"
                                    Margin="12,6"
                                    Padding="12,8"
                                    MinimumHeightRequest="48">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type pages:DeckDetailPage}}, Path=BindingContext.ShowCardQuickDetailCommand}"
                                                         CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto"
                                      ColumnSpacing="6"
                                      VerticalOptions="Center">
                                    <Border Grid.Column="0"
                                            WidthRequest="36"
                                            HeightRequest="50"
                                            BackgroundColor="{StaticResource Surface}"
                                            StrokeShape="RoundRectangle 4"
                                            Stroke="Transparent"
                                            VerticalOptions="Center">
                                        <controls:CachedCardImage CardUuid="{Binding ImageId}"
                                                                 HorizontalOptions="Fill"
                                                                 VerticalOptions="Fill" />
                                    </Border>
                                    <Border Grid.Column="1"
                                            BackgroundColor="{StaticResource Surface}"
                                            Padding="6,4"
                                            StrokeShape="RoundRectangle 8"
                                            Stroke="Transparent"
                                            VerticalOptions="Center"
                                            MinimumWidthRequest="28">
                                        <Label Text="{Binding Entity.Quantity}"
                                               TextColor="{StaticResource TextPrimary}"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               HorizontalOptions="Center" />
                                    </Border>
                                    <VerticalStackLayout Grid.Column="2"
                                                         Spacing="2"
                                                         VerticalOptions="Center">
                                        <Label Text="{Binding DisplayName}"
                                               TextColor="{StaticResource TextPrimary}"
                                               FontSize="14"
                                               LineBreakMode="TailTruncation" />
                                        <Label Text="{Binding CardTypeText}"
                                               TextColor="{StaticResource TextSecondary}"
                                               FontSize="11"
                                               LineBreakMode="TailTruncation" />
                                    </VerticalStackLayout>
                                    <Button Grid.Column="3"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type pages:DeckDetailPage}}, Path=BindingContext.DecrementCardCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="{StaticResource Surface}"
                                            TextColor="{StaticResource TextPrimary}"
                                            WidthRequest="36"
                                            HeightRequest="36"
                                            Padding="0"
                                            CornerRadius="6">
                                        <Button.ImageSource>
                                            <FontImageSource FontFamily="FASolid"
                                                             Glyph="{x:Static fa:Solid.Minus}"
                                                             Size="14"
                                                             Color="{StaticResource TextPrimary}" />
                                        </Button.ImageSource>
                                    </Button>
                                    <Button Grid.Column="4"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type pages:DeckDetailPage}}, Path=BindingContext.IncrementCardCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="{StaticResource Accent}"
                                            TextColor="Black"
                                            WidthRequest="36"
                                            HeightRequest="36"
                                            Padding="0"
                                            CornerRadius="6">
                                        <Button.ImageSource>
                                            <FontImageSource FontFamily="FASolid"
                                                             Glyph="{x:Static fa:Solid.Plus}"
                                                             Size="14"
                                                             Color="Black" />
                                        </Button.ImageSource>
                                    </Button>
                                </Grid>
                            </Border>
                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Sideboard Tab -->
            <CollectionView IsVisible="{Binding IsSideboardTab}"
                            ItemsSource="{Binding SideboardCards}"
                            SelectionMode="None">
                <CollectionView.Header>
                    <Label Text="Sideboard"
                           FontSize="12"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextSecondary}"
                           Padding="12,8,12,4" />
                </CollectionView.Header>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="vm:DeckCardDisplayItem">
                        <SwipeView>
                            <SwipeView.RightItems>
                                <SwipeItems>
                                    <SwipeItem Text="Remove"
                                               BackgroundColor="#B00020"
                                               Command="{Binding Source={RelativeSource AncestorType={x:Type pages:DeckDetailPage}}, Path=BindingContext.RemoveCardCommand}"
                                               CommandParameter="{Binding .}" />
                                </SwipeItems>
                            </SwipeView.RightItems>
                            <Border Style="{StaticResource CardStyle}"
                                    Margin="12,6"
                                    Padding="12,8"
                                    MinimumHeightRequest="48">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type pages:DeckDetailPage}}, Path=BindingContext.ShowCardQuickDetailCommand}"
                                                         CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <Grid ColumnDefinitions="Auto,Auto,*,Auto,Auto"
                                      ColumnSpacing="6"
                                      VerticalOptions="Center">
                                    <Border Grid.Column="0"
                                            WidthRequest="36"
                                            HeightRequest="50"
                                            BackgroundColor="{StaticResource Surface}"
                                            StrokeShape="RoundRectangle 4"
                                            Stroke="Transparent"
                                            VerticalOptions="Center">
                                        <controls:CachedCardImage CardUuid="{Binding ImageId}"
                                                                 HorizontalOptions="Fill"
                                                                 VerticalOptions="Fill" />
                                    </Border>
                                    <Border Grid.Column="1"
                                            BackgroundColor="{StaticResource Surface}"
                                            Padding="6,4"
                                            StrokeShape="RoundRectangle 8"
                                            Stroke="Transparent"
                                            VerticalOptions="Center"
                                            MinimumWidthRequest="28">
                                        <Label Text="{Binding Entity.Quantity}"
                                               TextColor="{StaticResource TextPrimary}"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               HorizontalOptions="Center" />
                                    </Border>
                                    <VerticalStackLayout Grid.Column="2"
                                                         Spacing="2"
                                                         VerticalOptions="Center">
                                        <Label Text="{Binding DisplayName}"
                                               TextColor="{StaticResource TextPrimary}"
                                               FontSize="14"
                                               LineBreakMode="TailTruncation" />
                                        <Label Text="{Binding CardTypeText}"
                                               TextColor="{StaticResource TextSecondary}"
                                               FontSize="11"
                                               LineBreakMode="TailTruncation" />
                                    </VerticalStackLayout>
                                    <Button Grid.Column="3"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type pages:DeckDetailPage}}, Path=BindingContext.DecrementCardCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="{StaticResource Surface}"
                                            TextColor="{StaticResource TextPrimary}"
                                            WidthRequest="36"
                                            HeightRequest="36"
                                            Padding="0"
                                            CornerRadius="6">
                                        <Button.ImageSource>
                                            <FontImageSource FontFamily="FASolid"
                                                             Glyph="{x:Static fa:Solid.Minus}"
                                                             Size="14"
                                                             Color="{StaticResource TextPrimary}" />
                                        </Button.ImageSource>
                                    </Button>
                                    <Button Grid.Column="4"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type pages:DeckDetailPage}}, Path=BindingContext.IncrementCardCommand}"
                                            CommandParameter="{Binding .}"
                                            BackgroundColor="{StaticResource Accent}"
                                            TextColor="Black"
                                            WidthRequest="36"
                                            HeightRequest="36"
                                            Padding="0"
                                            CornerRadius="6">
                                        <Button.ImageSource>
                                            <FontImageSource FontFamily="FASolid"
                                                             Glyph="{x:Static fa:Solid.Plus}"
                                                             Size="14"
                                                             Color="Black" />
                                        </Button.ImageSource>
                                    </Button>
                                </Grid>
                            </Border>
                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Stats Tab -->
            <ScrollView IsVisible="{Binding IsStatsTab}" Padding="16,8">
                <VerticalStackLayout Spacing="16">

                    <!-- Mana Curve Chart -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Mana Curve"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextSecondary}" />
                        <controls:ManaCurveView ManaCurve="{Binding Stats.ManaCurve}"
                                                HeightRequest="140"
                                                BackgroundColor="Transparent" />
                    </VerticalStackLayout>

                    <!-- Stats Grid -->
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Composition"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextSecondary}" />
                        <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto,Auto"
                              RowSpacing="8" ColumnSpacing="8">
                            <Border Style="{StaticResource CardStyle}" Grid.Row="0" Grid.Column="0">
                                <VerticalStackLayout HorizontalOptions="Center">
                                    <Label Text="{Binding Stats.TotalCards}" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{StaticResource Accent}" />
                                    <Label Text="Total" FontSize="11" TextColor="{StaticResource TextSecondary}" HorizontalOptions="Center" />
                                </VerticalStackLayout>
                            </Border>
                            <Border Style="{StaticResource CardStyle}" Grid.Row="0" Grid.Column="1">
                                <VerticalStackLayout HorizontalOptions="Center">
                                    <Label Text="{Binding Stats.AvgCMC, StringFormat='{0:F1}'}" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{StaticResource Accent}" />
                                    <Label Text="Avg CMC" FontSize="11" TextColor="{StaticResource TextSecondary}" HorizontalOptions="Center" />
                                </VerticalStackLayout>
                            </Border>
                            <Border Style="{StaticResource CardStyle}" Grid.Row="0" Grid.Column="2">
                                <VerticalStackLayout HorizontalOptions="Center">
                                    <Label Text="{Binding Stats.Lands}" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{StaticResource Accent}" />
                                    <Label Text="Lands" FontSize="11" TextColor="{StaticResource TextSecondary}" HorizontalOptions="Center" />
                                </VerticalStackLayout>
                            </Border>
                            <Border Style="{StaticResource CardStyle}" Grid.Row="1" Grid.Column="0">
                                <VerticalStackLayout HorizontalOptions="Center">
                                    <Label Text="{Binding Stats.Creatures}" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{StaticResource TextPrimary}" />
                                    <Label Text="Creatures" FontSize="11" TextColor="{StaticResource TextSecondary}" HorizontalOptions="Center" />
                                </VerticalStackLayout>
                            </Border>
                            <Border Style="{StaticResource CardStyle}" Grid.Row="1" Grid.Column="1">
                                <VerticalStackLayout HorizontalOptions="Center">
                                    <Label Text="{Binding Stats.Instants}" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{StaticResource TextPrimary}" />
                                    <Label Text="Instants" FontSize="11" TextColor="{StaticResource TextSecondary}" HorizontalOptions="Center" />
                                </VerticalStackLayout>
                            </Border>
                            <Border Style="{StaticResource CardStyle}" Grid.Row="1" Grid.Column="2">
                                <VerticalStackLayout HorizontalOptions="Center">
                                    <Label Text="{Binding Stats.Sorceries}" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{StaticResource TextPrimary}" />
                                    <Label Text="Sorceries" FontSize="11" TextColor="{StaticResource TextSecondary}" HorizontalOptions="Center" />
                                </VerticalStackLayout>
                            </Border>
                            <Border Style="{StaticResource CardStyle}" Grid.Row="2" Grid.Column="0">
                                <VerticalStackLayout HorizontalOptions="Center">
                                    <Label Text="{Binding Stats.Artifacts}" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{StaticResource TextPrimary}" />
                                    <Label Text="Artifacts" FontSize="11" TextColor="{StaticResource TextSecondary}" HorizontalOptions="Center" />
                                </VerticalStackLayout>
                            </Border>
                            <Border Style="{StaticResource CardStyle}" Grid.Row="2" Grid.Column="1">
                                <VerticalStackLayout HorizontalOptions="Center">
                                    <Label Text="{Binding Stats.Enchantments}" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{StaticResource TextPrimary}" />
                                    <Label Text="Enchants" FontSize="11" TextColor="{StaticResource TextSecondary}" HorizontalOptions="Center" />
                                </VerticalStackLayout>
                            </Border>
                            <Border Style="{StaticResource CardStyle}" Grid.Row="2" Grid.Column="2">
                                <VerticalStackLayout HorizontalOptions="Center">
                                    <Label Text="{Binding Stats.Planeswalkers}" FontSize="22" FontAttributes="Bold" HorizontalOptions="Center" TextColor="{StaticResource TextPrimary}" />
                                    <Label Text="Planeswalkers" FontSize="11" TextColor="{StaticResource TextSecondary}" HorizontalOptions="Center" />
                                </VerticalStackLayout>
                            </Border>
                        </Grid>
                    </VerticalStackLayout>

                    <!-- Bulk land helper -->
                    <Button Text="Auto-suggest lands"
                            Command="{Binding SuggestLandsCommand}"
                            BackgroundColor="{StaticResource Accent}"
                            TextColor="Black"
                            FontSize="13"
                            HeightRequest="40"
                            CornerRadius="20"
                            HorizontalOptions="Center"
                            Margin="0,8,0,0" />

                    <!-- Status message -->
                    <Label Text="{Binding StatusDisplayText}"
                           FontSize="12"
                           TextColor="{Binding StatusTextColor}"
                           HorizontalOptions="Center" />

                </VerticalStackLayout>
            </ScrollView>

        </Grid>

        <!-- Row 5: Footer -->
        <Grid Grid.Row="5"
              Padding="12,8"
              BackgroundColor="{StaticResource Surface}">
            <Label Text="{Binding StatusDisplayText}"
                   FontSize="12"
                   TextColor="{Binding StatusTextColor}"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />
        </Grid>

    </Grid>

    <ContentPage.Resources>
        <ResourceDictionary>
            <toolkit:InvertedBoolConverter x:Key="InvertBool" />
        </ResourceDictionary>
    </ContentPage.Resources>

</ContentPage>
