<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
               xmlns:uranium="http://schemas.enisn-projects.io/dotnet/maui/uraniumui"
               xmlns:controls="clr-namespace:AetherVault.Controls"
               xmlns:viewmodels="clr-namespace:AetherVault.ViewModels"
               xmlns:models="clr-namespace:AetherVault.Models"
               x:Class="AetherVault.Pages.SearchFiltersSheet"
               x:DataType="viewmodels:SearchFiltersViewModel"
               x:Name="SheetRoot"
               CanBeDismissedByTappingOutsideOfPopup="True"
               HorizontalOptions="Fill"
               VerticalOptions="End"
               BackgroundColor="Transparent">

    <toolkit:Popup.Resources>
        <ResourceDictionary>
            <OnIdiom x:Key="HeaderFontSize" x:TypeArguments="x:Double" Phone="18" Tablet="20" Desktop="20" />
            <OnIdiom x:Key="BodyFontSize"   x:TypeArguments="x:Double" Phone="14" Tablet="16" Desktop="16" />
            <OnIdiom x:Key="SmallFontSize"  x:TypeArguments="x:Double" Phone="12" Tablet="14" Desktop="14" />

            <!-- Section container: padding, margin; matches inline filter strip card style -->
            <Style x:Key="FilterSectionStyle" TargetType="Border">
                <Setter Property="Padding" Value="18" />
                <Setter Property="Margin" Value="0,4,0,4" />
                <Setter Property="BackgroundColor" Value="{StaticResource Background}" />
                <Setter Property="Stroke" Value="Transparent" />
                <Setter Property="StrokeThickness" Value="0" />
                <Setter Property="StrokeShape" Value="RoundRectangle 8" />
            </Style>

            <!-- Color filter item template: 44pt touch target, ~32pt visual, margin 6 -->
            <DataTemplate x:Key="ColorFilterItemTemplate" x:DataType="models:ColorFilterItem">
                <Grid WidthRequest="44" HeightRequest="44" Margin="6"
                      Opacity="0.5" Scale="1">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer
                            Command="{Binding Source={RelativeSource AncestorType={x:Type toolkit:Popup}}, Path=BindingContext.ToggleColorCommand}"
                            CommandParameter="{Binding Code}" />
                    </Grid.GestureRecognizers>
                    <controls:ManaSymbolView Symbol="{Binding Code}"
                                            InputTransparent="True"
                                            WidthRequest="32"
                                            HeightRequest="32"
                                            VerticalOptions="Center"
                                            HorizontalOptions="Center" />
                    <Grid.Triggers>
                        <DataTrigger TargetType="Grid" Binding="{Binding IsSelected}" Value="True">
                            <DataTrigger.Setters>
                                <Setter Property="Opacity" Value="1" />
                                <Setter Property="Scale" Value="1.1" />
                            </DataTrigger.Setters>
                        </DataTrigger>
                    </Grid.Triggers>
                </Grid>
            </DataTemplate>
        </ResourceDictionary>
    </toolkit:Popup.Resources>

    <Border BackgroundColor="{StaticResource CardBackground}"
            StrokeThickness="0"
            StrokeShape="RoundRectangle 20,20,0,0"
            Margin="0"
            VerticalOptions="End"
            HorizontalOptions="Fill">
        <Border.Shadow>
            <Shadow Brush="Black" Offset="0,-2" Radius="12" Opacity="0.3" />
        </Border.Shadow>

        <Grid RowDefinitions="Auto,*,Auto"
              MinimumHeightRequest="420"
              MaximumHeightRequest="720">

            <!-- Sheet header: drag handle + title + active filter badge -->
            <VerticalStackLayout Grid.Row="0" Spacing="6" Padding="24,16,24,8"
                                BackgroundColor="Transparent">
                <BoxView HeightRequest="4" WidthRequest="40" HorizontalOptions="Center"
                         Color="{StaticResource TextSecondary}" Opacity="0.8"
                         CornerRadius="2" />
                <Label Text="Search filters"
                       FontSize="{StaticResource HeaderFontSize}"
                       FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}"
                       HorizontalOptions="Center" />
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8"
                      IsVisible="{Binding HasActiveFilters}">
                    <Label Text="{Binding FiltersSummaryText}"
                           FontSize="{StaticResource SmallFontSize}"
                           TextColor="{StaticResource TextSecondary}"
                           LineBreakMode="TailTruncation"
                           MaxLines="2"
                           VerticalOptions="Center" />
                    <Button Grid.Column="1"
                            Text="Clear"
                            Command="{Binding ClearAllCommand}"
                            BackgroundColor="Transparent"
                            TextColor="{StaticResource Primary}"
                            FontSize="{StaticResource SmallFontSize}"
                            Padding="12,6"
                            VerticalOptions="Center" />
                </Grid>
            </VerticalStackLayout>

            <ScrollView Grid.Row="1" Padding="16,12,16,16">
                <VerticalStackLayout Spacing="32">

                    <!-- Colors -->
                    <Border Style="{StaticResource FilterSectionStyle}">
                        <uranium:ExpanderView IsExpanded="True">
                            <uranium:ExpanderView.Header>
                                <Label Text="Colors" FontSize="{StaticResource BodyFontSize}" FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}" />
                            </uranium:ExpanderView.Header>
                            <FlexLayout BindableLayout.ItemsSource="{Binding ColorFilters}"
                                        BindableLayout.ItemTemplate="{StaticResource ColorFilterItemTemplate}"
                                        Wrap="Wrap" JustifyContent="Start" AlignItems="Start"
                                        Margin="0,8,0,0" />
                        </uranium:ExpanderView>
                    </Border>

                    <!-- Card Text / Type -->
                    <Border Style="{StaticResource FilterSectionStyle}">
                        <uranium:ExpanderView IsExpanded="True">
                            <uranium:ExpanderView.Header>
                                <Label Text="Text &amp; type" FontSize="{StaticResource BodyFontSize}" FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}" />
                            </uranium:ExpanderView.Header>
                            <VerticalStackLayout Spacing="12" Margin="0,8,0,0">
                                <material:TextField Text="{Binding Keywords, Mode=TwoWay}"
                                                    Title="Card Text"
                                                    TitleColor="{StaticResource TextSecondary}"
                                                    AccentColor="{StaticResource Primary}"
                                                    MinimumHeightRequest="56" />
                                <material:PickerField SelectedIndex="{Binding SelectedTypeIndex, Mode=TwoWay}"
                                                       ItemsSource="{Binding TypeOptions}"
                                                       Title="Card Type"
                                                       TextColor="{StaticResource TextPrimary}"
                                                       TitleColor="{StaticResource TextSecondary}"
                                                       AccentColor="{StaticResource Primary}"
                                                       MinimumHeightRequest="56"
                                                       Margin="0,6,0,6" />
                                <material:TextField Text="{Binding Subtype, Mode=TwoWay}"
                                                    Title="Subtype"
                                                    TitleColor="{StaticResource TextSecondary}"
                                                    AccentColor="{StaticResource Primary}"
                                                    MinimumHeightRequest="56"
                                                    Margin="0,6,0,6" />
                                <material:TextField Text="{Binding Supertype, Mode=TwoWay}"
                                                    Title="Supertype"
                                                    TitleColor="{StaticResource TextSecondary}"
                                                    AccentColor="{StaticResource Primary}"
                                                    MinimumHeightRequest="56"
                                                    Margin="0,6,0,6" />
                            </VerticalStackLayout>
                        </uranium:ExpanderView>
                    </Border>

                    <!-- Rarity -->
                    <Border Style="{StaticResource FilterSectionStyle}">
                        <uranium:ExpanderView IsExpanded="True">
                            <uranium:ExpanderView.Header>
                                <Label Text="Rarity" FontSize="{StaticResource BodyFontSize}" FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}" />
                            </uranium:ExpanderView.Header>
                            <Grid RowDefinitions="Auto,Auto"
                                  ColumnDefinitions="*,*"
                                  ColumnSpacing="20"
                                  RowSpacing="12"
                                  Margin="0,8,0,0">
                                <material:CheckBox Grid.Row="0" Grid.Column="0"
                                                   IsChecked="{Binding ChkCommon, Mode=TwoWay}"
                                                   Text="Common"
                                                   Color="{StaticResource Primary}" />
                                <material:CheckBox Grid.Row="0" Grid.Column="1"
                                                   IsChecked="{Binding ChkUncommon, Mode=TwoWay}"
                                                   Text="Uncommon"
                                                   Color="{StaticResource Primary}" />
                                <material:CheckBox Grid.Row="1" Grid.Column="0"
                                                   IsChecked="{Binding ChkRare, Mode=TwoWay}"
                                                   Text="Rare"
                                                   Color="{StaticResource Primary}" />
                                <material:CheckBox Grid.Row="1" Grid.Column="1"
                                                   IsChecked="{Binding ChkMythic, Mode=TwoWay}"
                                                   Text="Mythic"
                                                   Color="{StaticResource Primary}" />
                            </Grid>
                        </uranium:ExpanderView>
                    </Border>

                    <!-- CMC Range: stacked vertically for mobile -->
                    <Border Style="{StaticResource FilterSectionStyle}">
                        <uranium:ExpanderView IsExpanded="False">
                            <uranium:ExpanderView.Header>
                                <Label Text="Mana value (CMC)" FontSize="{StaticResource BodyFontSize}" FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}" />
                            </uranium:ExpanderView.Header>
                            <VerticalStackLayout Spacing="8" Margin="0,8,0,0">
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="{Binding CmcMinLabel}"
                                           FontSize="{StaticResource SmallFontSize}"
                                           TextColor="{StaticResource TextSecondary}" />
                                    <Slider Minimum="0" Maximum="16"
                                            Value="{Binding CmcMin, Mode=TwoWay}"
                                            ThumbColor="{StaticResource Primary}"
                                            MinimumTrackColor="{StaticResource Primary}" />
                                </VerticalStackLayout>
                                <Label Text="to"
                                       FontSize="{StaticResource BodyFontSize}"
                                       TextColor="{StaticResource TextSecondary}"
                                       HorizontalOptions="Center" />
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="{Binding CmcMaxLabel}"
                                           FontSize="{StaticResource SmallFontSize}"
                                           TextColor="{StaticResource TextSecondary}" />
                                    <Slider Minimum="0" Maximum="16"
                                            Value="{Binding CmcMax, Mode=TwoWay}"
                                            ThumbColor="{StaticResource Primary}"
                                            MinimumTrackColor="{StaticResource Primary}" />
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </uranium:ExpanderView>
                    </Border>

                    <!-- Power / Toughness: stacked vertically for mobile -->
                    <Border Style="{StaticResource FilterSectionStyle}">
                        <uranium:ExpanderView IsExpanded="False">
                            <uranium:ExpanderView.Header>
                                <Label Text="Power &amp; toughness" FontSize="{StaticResource BodyFontSize}" FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}" />
                            </uranium:ExpanderView.Header>
                            <VerticalStackLayout Spacing="12" Margin="0,8,0,0">
                                <material:TextField Text="{Binding Power, Mode=TwoWay}"
                                                    Title="Power"
                                                    Keyboard="Numeric"
                                                    TitleColor="{StaticResource TextSecondary}"
                                                    AccentColor="{StaticResource Primary}"
                                                    MinimumHeightRequest="56"
                                                    Margin="0,4,0,4" />
                                <material:TextField Text="{Binding Toughness, Mode=TwoWay}"
                                                    Title="Toughness"
                                                    Keyboard="Numeric"
                                                    TitleColor="{StaticResource TextSecondary}"
                                                    AccentColor="{StaticResource Primary}"
                                                    MinimumHeightRequest="56"
                                                    Margin="0,4,0,4" />
                            </VerticalStackLayout>
                        </uranium:ExpanderView>
                    </Border>

                    <!-- Format / Set / Artist -->
                    <Border Style="{StaticResource FilterSectionStyle}">
                        <uranium:ExpanderView IsExpanded="False">
                            <uranium:ExpanderView.Header>
                                <Label Text="Set &amp; format" FontSize="{StaticResource BodyFontSize}" FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}" />
                            </uranium:ExpanderView.Header>
                            <VerticalStackLayout Spacing="20" Margin="0,8,0,0">
                                <material:PickerField SelectedIndex="{Binding SelectedFormatIndex, Mode=TwoWay}"
                                                       ItemsSource="{Binding FormatOptions}"
                                                       Title="Format"
                                                       TextColor="{StaticResource TextPrimary}"
                                                       TitleColor="{StaticResource TextSecondary}"
                                                       AccentColor="{StaticResource Primary}"
                                                       MinimumHeightRequest="56"
                                                       Margin="0,6,0,6" />

                                <Grid Margin="0,6,0,6"
                                      MinimumHeightRequest="56"
                                      ColumnDefinitions="*"
                                      RowDefinitions="Auto,*">
                                    <Label Text="Set"
                                           FontSize="12"
                                           TextColor="{StaticResource TextSecondary}"
                                           Margin="0,0,0,4" />
                                    <Border Grid.Row="1"
                                            BackgroundColor="Transparent"
                                            Padding="0,8,0,8"
                                            StrokeThickness="0"
                                            StrokeShape="RoundRectangle 4">
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnSetFieldTapped" />
                                        </Border.GestureRecognizers>
                                        <Grid ColumnDefinitions="*,Auto">
                                            <Label Text="{Binding SelectedSetDisplayName}"
                                                   FontSize="14"
                                                   TextColor="{StaticResource TextPrimary}"
                                                   VerticalOptions="Center"
                                                   LineBreakMode="TailTruncation" />
                                            <Label Grid.Column="1"
                                                   Text="˅"
                                                   FontSize="12"
                                                   TextColor="{StaticResource TextSecondary}"
                                                   VerticalOptions="Center" />
                                        </Grid>
                                    </Border>
                                </Grid>

                                <material:TextField Text="{Binding Artist, Mode=TwoWay}"
                                                    Title="Artist"
                                                    TitleColor="{StaticResource TextSecondary}"
                                                    AccentColor="{StaticResource Primary}"
                                                    MinimumHeightRequest="56"
                                                    Margin="0,6,0,6" />
                            </VerticalStackLayout>
                        </uranium:ExpanderView>
                    </Border>

                    <!-- Special Options -->
                    <Border Style="{StaticResource FilterSectionStyle}">
                        <uranium:ExpanderView IsExpanded="False">
                            <uranium:ExpanderView.Header>
                                <Label Text="Options" FontSize="{StaticResource BodyFontSize}" FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}" />
                            </uranium:ExpanderView.Header>
                            <VerticalStackLayout Spacing="6" Margin="0,8,0,0">
                                <material:CheckBox IsChecked="{Binding ChkPrimarySide, Mode=TwoWay}"
                                                   Text="Primary side only"
                                                   Color="{StaticResource Primary}"
                                                   Margin="0,6,0,6" />
                                <material:CheckBox IsChecked="{Binding ChkNoVariations, Mode=TwoWay}"
                                                   Text="Exclude variations"
                                                   Color="{StaticResource Primary}"
                                                   Margin="0,6,0,6" />
                                <material:CheckBox IsChecked="{Binding ChkIncludeTokens, Mode=TwoWay}"
                                                   Text="Include tokens"
                                                   Color="{StaticResource Primary}"
                                                   Margin="0,6,0,6" />
                                <material:CheckBox IsChecked="{Binding ChkCommanderOnly, Mode=TwoWay}"
                                                   Text="Can be commander only"
                                                   Color="{StaticResource Primary}"
                                                   Margin="0,6,0,6" />
                            </VerticalStackLayout>
                        </uranium:ExpanderView>
                    </Border>

                </VerticalStackLayout>
            </ScrollView>

            <!-- Bottom button row with separator; equal-width buttons so Cancel doesn't truncate -->
            <BoxView Grid.Row="2" HeightRequest="1" Color="{StaticResource CardBackground}" />
            <Grid Grid.Row="2"
                  Padding="24,16,24,28"
                  ColumnDefinitions="*,*,*"
                  ColumnSpacing="12"
                  BackgroundColor="{StaticResource CardBackground}">
                <Button Text="Reset"
                        Command="{Binding ResetCommand}"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource TextSecondary}"
                        BorderColor="{StaticResource TextSecondary}"
                        BorderWidth="1"
                        HorizontalOptions="Fill"
                        FontSize="14"
                        MinimumHeightRequest="44"
                        Padding="8,14" />
                <Button Grid.Column="1"
                        Text="Cancel"
                        Command="{Binding CancelCommand}"
                        BackgroundColor="{StaticResource CardBackground}"
                        TextColor="{StaticResource TextPrimary}"
                        HorizontalOptions="Fill"
                        FontSize="14"
                        MinimumHeightRequest="44"
                        Padding="8,14" />
                <Button Grid.Column="2"
                        Text="Apply"
                        Command="{Binding ApplyCommand}"
                        BackgroundColor="{StaticResource Primary}"
                        TextColor="White"
                        HorizontalOptions="Fill"
                        FontSize="14"
                        MinimumHeightRequest="44"
                        Padding="8,14" />
            </Grid>

        </Grid>

    </Border>

</toolkit:Popup>
