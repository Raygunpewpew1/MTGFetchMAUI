<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:controls="clr-namespace:AetherVault.Controls"
             xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
             xmlns:models="clr-namespace:AetherVault.Models"
             xmlns:vm="clr-namespace:AetherVault.ViewModels"
             xmlns:pages="clr-namespace:AetherVault.Pages"
             xmlns:fa="clr-namespace:UraniumUI.Icons.FontAwesome;assembly=UraniumUI.Icons.FontAwesome"
             xmlns:converters="clr-namespace:AetherVault.Converters"
             x:Class="AetherVault.Pages.CardSearchPickerPage"
             Title="Select a Card"
             BackgroundColor="{StaticResource Background}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <toolkit:InvertedBoolConverter x:Key="InvertedBoolConverter" />
            <converters:UrlToImageSourceConverter x:Key="UrlToImageSource" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Search Bar -->
        <VerticalStackLayout Grid.Row="0" Spacing="4" Padding="8,8,8,4">
            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                <material:TextField x:Name="SearchEntry"
                       Title="Search cards..."
                       Text="{Binding SearchText, Mode=TwoWay}"
                       ReturnCommand="{Binding SearchCommand}"
                       BackgroundColor="{StaticResource Surface}"
                       TextColor="{StaticResource TextPrimary}"
                       TitleColor="{StaticResource TextSecondary}"
                       AccentColor="{StaticResource Primary}"
                       AllowClear="True">
                </material:TextField>

                <Button Grid.Column="1"
                        x:Name="FiltersButton"
                        Text="{Binding FiltersButtonText}"
                        Clicked="OnFiltersClicked"
                        BackgroundColor="{StaticResource CardBackground}"
                        HeightRequest="44"
                        Padding="12,0"
                        StyleClass="ElevatedButton" />

                <Button Grid.Column="2"
                        Text="{Binding ViewModeButtonText}"
                        Command="{Binding ToggleViewModeCommand}"
                        BackgroundColor="{StaticResource CardBackground}"
                        HeightRequest="44"
                        WidthRequest="44"
                        Padding="0"
                        FontSize="18"
                        StyleClass="ElevatedButton" />
            </Grid>

            <HorizontalStackLayout Spacing="8" Margin="4,0,0,0" VerticalOptions="Center">
                <CheckBox IsChecked="{Binding SearchCollectionOnly}"
                          Color="{StaticResource Primary}"
                          VerticalOptions="Center" />
                <Label Text="Search my collection only"
                       FontSize="13"
                       TextColor="{StaticResource TextSecondary}"
                       VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ToggleCollectionOnlyCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>
        </VerticalStackLayout>

        <!-- Status Bar -->
        <Grid Grid.Row="1" Padding="8,0,8,4">
            <Label x:Name="StatusLabel"
                   Text="{Binding StatusDisplayText}"
                   TextColor="{Binding StatusTextColor}"
                   FontSize="12" />
            <ActivityIndicator x:Name="LoadingIndicator"
                               IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               HorizontalOptions="End"
                               HeightRequest="20"
                               WidthRequest="20"
                               Color="{StaticResource Primary}" />
        </Grid>

        <!-- Card List (hidden when no results so empty state shows) -->
        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding SearchResults}"
                        IsVisible="{Binding IsEmpty, Converter={StaticResource InvertedBoolConverter}}"
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Card">
                    <Grid Padding="12,8" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" BackgroundColor="{StaticResource Background}">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type pages:CardSearchPickerPage}}, Path=BindingContext.SelectCardCommand}"
                                CommandParameter="{Binding .}" />
                        </Grid.GestureRecognizers>

                        <Border Grid.Column="0" WidthRequest="40" HeightRequest="56" BackgroundColor="{StaticResource Surface}" StrokeShape="RoundRectangle 4">
                            <Image Source="{Binding ImageUrl, Converter={StaticResource UrlToImageSource}}" Aspect="AspectFill" />
                        </Border>

                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label Text="{Binding Name}" TextColor="{StaticResource TextPrimary}" FontSize="15" FontAttributes="Bold" LineBreakMode="TailTruncation" />
                            <Label Text="{Binding CardType}" TextColor="{StaticResource TextSecondary}" FontSize="12" LineBreakMode="TailTruncation" />
                        </VerticalStackLayout>

                        <controls:ManaCostView Grid.Column="2" ManaText="{Binding ManaCost}" SymbolSize="12" VerticalOptions="Center" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Empty State -->
        <VerticalStackLayout Grid.Row="2"
                             IsVisible="{Binding IsEmpty}"
                             VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="8">
            <Label FontFamily="FASolid"
                   Text="{x:Static fa:Solid.MagnifyingGlass}"
                   FontSize="44"
                   TextColor="{StaticResource TextSecondary}"
                   HorizontalOptions="Center" />
            <Label Text="No cards found"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="{StaticResource TextPrimary}"
                   HorizontalOptions="Center" />
            <Label Text="Try a different search or adjust your filters"
                   FontSize="13"
                   TextColor="{StaticResource TextSecondary}"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>