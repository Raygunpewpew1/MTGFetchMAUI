<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:AetherVault.Controls"
             xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
             xmlns:models="clr-namespace:AetherVault.Models"
             xmlns:vm="clr-namespace:AetherVault.ViewModels"
             xmlns:pages="clr-namespace:AetherVault.Pages"
             xmlns:fa="clr-namespace:UraniumUI.Icons.FontAwesome;assembly=UraniumUI.Icons.FontAwesome"
             x:Class="AetherVault.Pages.CardSearchPickerPage"
             Title="Select a Card"
             BackgroundColor="{StaticResource Background}">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Search Bar -->
        <VerticalStackLayout Grid.Row="0" Spacing="4" Padding="8,8,8,4">
            <controls:CardSearchBar x:Name="SearchBar" />

            <HorizontalStackLayout Spacing="8" Margin="4,0,0,0" VerticalOptions="Center">
                <CheckBox IsChecked="{Binding SearchCollectionOnly}"
                          Color="{StaticResource Primary}"
                          VerticalOptions="Center" />
                <Label Text="Search my collection only"
                       FontSize="13"
                       TextColor="{StaticResource TextSecondary}"
                       VerticalOptions="Center">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding ToggleCollectionOnlyCommand}" />
                    </Label.GestureRecognizers>
                </Label>
            </HorizontalStackLayout>
        </VerticalStackLayout>

        <!-- Status Bar -->
        <Grid Grid.Row="1" Padding="8,0,8,4">
            <Label x:Name="StatusLabel"
                   Text="{Binding StatusDisplayText}"
                   TextColor="{Binding StatusTextColor}"
                   FontSize="12" />
            <ActivityIndicator x:Name="LoadingIndicator"
                               IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               HorizontalOptions="End"
                               HeightRequest="20"
                               WidthRequest="20"
                               Color="{StaticResource Primary}" />
        </Grid>

        <!-- Card List (hidden when no results so empty state shows; non-interactive while search in progress) -->
        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding SearchResults}"
                        IsVisible="{Binding IsEmpty, Converter={StaticResource InvertedBool}}"
                        InputTransparent="{Binding IsBusy}"
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Card">
                    <Grid Padding="12,8" ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" BackgroundColor="{StaticResource Background}">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type pages:CardSearchPickerPage}}, Path=BindingContext.SelectCardCommand}"
                                CommandParameter="{Binding .}" />
                        </Grid.GestureRecognizers>

                        <Border Grid.Column="0" WidthRequest="40" HeightRequest="56" BackgroundColor="{StaticResource Surface}" StrokeShape="RoundRectangle 4">
                            <controls:CachedCardImage CardUuid="{Binding ImageId}" HorizontalOptions="Fill" VerticalOptions="Fill" />
                        </Border>

                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="2">
                            <Label Text="{Binding Name}" TextColor="{StaticResource TextPrimary}" FontSize="15" FontAttributes="Bold" LineBreakMode="TailTruncation" />
                            <Label Text="{Binding CardType}" TextColor="{StaticResource TextSecondary}" FontSize="12" LineBreakMode="TailTruncation" />
                        </VerticalStackLayout>

                        <controls:ManaCostView Grid.Column="2" ManaText="{Binding ManaCost}" SymbolSize="12" VerticalOptions="Center" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Empty State -->
        <controls:EmptyStateView Grid.Row="2"
                                 IsVisible="{Binding IsEmpty}"
                                 IconGlyph="{x:Static fa:Solid.MagnifyingGlass}"
                                 Message="No cards found"
                                 SecondaryMessage="Try a different search or adjust your filters" />
    </Grid>
</ContentPage>