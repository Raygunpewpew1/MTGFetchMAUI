<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:AetherVault.Controls"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
             xmlns:uranium="http://schemas.enisn-projects.io/dotnet/maui/uraniumui"
             xmlns:models="clr-namespace:AetherVault.Models"
             xmlns:core="clr-namespace:AetherVault.Core"
             xmlns:converters="clr-namespace:AetherVault.Converters"
             xmlns:services="clr-namespace:AetherVault.Services"
             xmlns:viewmodels="clr-namespace:AetherVault.ViewModels"
             x:Class="AetherVault.Pages.CardDetailPage"
             x:Name="DetailScreen"
             Title="Card Details"
             BackgroundColor="{StaticResource Background}"
             Shell.PresentationMode="Animated">

    <Shell.BackButtonBehavior>
        <BackButtonBehavior Command="{Binding BindingContext.BackCommand, Source={x:Reference DetailScreen}}" />
    </Shell.BackButtonBehavior>

    <Grid RowDefinitions="*,Auto,Auto">

        <ScrollView Grid.Row="0">
            <!-- SwipeGestureContainer wraps the content instead of overlaying it.
                 This allows children (buttons, expanders) to receive touches while
                 still capturing horizontal swipes for navigation. -->
            <controls:SwipeGestureContainer x:Name="SwipeContainer">
                <VerticalStackLayout x:Name="CardContentRoot"
                                     Padding="16"
                                     Spacing="8">

                    <Border StrokeShape="RoundRectangle 12"
                            StrokeThickness="0"
                            HeightRequest="380"
                            HorizontalOptions="Center"
                            WidthRequest="272">
                        <Grid>
                            <skia:SKCanvasView x:Name="CardImageView"
                                               PaintSurface="OnCardImagePaint"
                                               EnableTouchEvents="True"
                                               Touch="CardImageView_Touch"
                                               HeightRequest="380"
                                               WidthRequest="272" />
                            <ActivityIndicator x:Name="ImageLoading"
                                               IsRunning="{Binding IsImageLoading}"
                                               IsVisible="{Binding IsImageLoading}"
                                               VerticalOptions="Center"
                                               HorizontalOptions="Center"
                                               Color="{StaticResource Primary}" />
                            <VerticalStackLayout x:Name="ImageFallback"
                                                 IsVisible="{Binding CardImageLoadFailed}"
                                                 VerticalOptions="Center"
                                                 HorizontalOptions="Center"
                                                 Spacing="6">
                                <Label Text="&#x1F5BC;"
                                       FontSize="36"
                                       HorizontalOptions="Center" />
                                <Label Text="Image unavailable"
                                       FontSize="12"
                                       TextColor="{StaticResource TextSecondary}"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                <Label Text="{Binding CardPosition}"
                       IsVisible="{Binding ShowGalleryNavigation}"
                       HorizontalOptions="Center"
                       FontSize="11"
                       TextColor="{StaticResource TextSecondary}" />

                <Label x:Name="SwipeHintLabel"
                       Text="Swipe left or right to browse cards"
                       HorizontalOptions="Center"
                       FontSize="11"
                       Opacity="0"
                       TextColor="{StaticResource TextSecondary}" />

                <Label x:Name="FlipHint"
                       Text="Tap image to flip"
                       IsVisible="{Binding HasMultipleFaces}"
                       HorizontalOptions="Center"
                       FontSize="11"
                       TextColor="{StaticResource TextSecondary}" />

                <Border Style="{StaticResource CardStyle}"
                        Margin="0,8,0,0">
                    <VerticalStackLayout Spacing="4">
                        <Grid ColumnDefinitions="*,Auto">
                            <Label x:Name="CardNameLabel"
                                   Text="{Binding CurrentFace.Name}"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextPrimary}"
                                   LineBreakMode="WordWrap"
                                   FontAutoScalingEnabled="True" />
                            <controls:ManaCostView x:Name="ManaCost"
                                                   ManaText="{Binding CurrentFace.ManaCost}"
                                                   Grid.Column="1"
                                                   VerticalOptions="Center" />
                        </Grid>

                        <Label x:Name="TypeLineLabel"
                               Text="{Binding CurrentFace.CardType}"
                               FontSize="14"
                               TextColor="{StaticResource TextSecondary}" />

                        <HorizontalStackLayout Spacing="8"
                                               VerticalOptions="Center">
                            <skia:SKCanvasView x:Name="SetSymbolView"
                                               HeightRequest="24"
                                               WidthRequest="24"
                                               PaintSurface="OnSetSymbolPaint"
                                               IsVisible="{Binding IsSetSymbolVisible}" />
                            <Label x:Name="SetInfoLabel"
                                   Text="{Binding SetInfoText}"
                                   VerticalOptions="Center"
                                   FontSize="12"
                                   LineBreakMode="WordWrap"
                                   TextColor="{StaticResource TextSecondary}" />
                            <Label x:Name="RarityLabel"
                                   Text="{Binding CurrentFace.Rarity}"
                                   TextColor="{Binding RarityColor}"
                                   VerticalOptions="Center"
                                   FontSize="12"
                                   FontAttributes="Bold" />
                        </HorizontalStackLayout>

                        <Label x:Name="PriceLabel"
                               Text="{Binding PriceDisplay}"
                               FontSize="14"
                               FontAttributes="Bold"
                               TextColor="{StaticResource Accent}"
                               IsVisible="{Binding IsPriceVisible}" />

                        <Label x:Name="PTLabel"
                               Text="{Binding PTText}"
                               FontSize="14"
                               TextColor="{StaticResource TextPrimary}"
                               IsVisible="{Binding IsPTVisible}" />
                    </VerticalStackLayout>
                </Border>

                <Border x:Name="PriceHistoryBorder"
                        Style="{StaticResource CardStyle}"
                        IsVisible="{Binding HasPriceHistory}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Price Trend (Last 90 Days)"
                               FontSize="16"
                               FontAttributes="Bold"
                               Margin="0,0,0,4" />
                        <VerticalStackLayout x:Name="HistoryStack" Spacing="4" BindableLayout.ItemsSource="{Binding DisplayPriceHistory}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="viewmodels:PriceHistoryPoint">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="{Binding Label}" FontSize="13" FontAttributes="Bold" Margin="0,4,0,2" />
                                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding Points}">
                                            <BindableLayout.ItemTemplate>
                                                <DataTemplate x:DataType="services:PriceEntry">
                                                    <Grid ColumnDefinitions="*,Auto">
                                                        <Label Text="{Binding Date, StringFormat='{0:d}'}" FontSize="12" TextColor="#A0A0A0" />
                                                        <Label Text="{Binding Price, StringFormat='${0:F2}'}" FontSize="12" HorizontalTextAlignment="End" Grid.Column="1" />
                                                    </Grid>
                                                </DataTemplate>
                                            </BindableLayout.ItemTemplate>
                                        </VerticalStackLayout>
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <Border x:Name="TextBorder"
                        Style="{StaticResource CardStyle}"
                        IsVisible="{Binding IsTextVisible}">
                    <controls:CardTextView x:Name="CardTextView"
                                           CardText="{Binding CombinedText}"
                                           HorizontalOptions="Fill"
                                           TextColor="{StaticResource TextPrimary}" />
                </Border>

                <Border x:Name="FlavorBorder"
                        Style="{StaticResource CardStyle}"
                        IsVisible="{Binding IsFlavorVisible}">
                    <Label x:Name="FlavorTextLabel"
                           Text="{Binding CurrentFace.FlavorText}"
                           FontAttributes="Italic" 
                           FontSize="13"
                           TextColor="{StaticResource TextSecondary}"
                           LineBreakMode="WordWrap" />
                </Border>

                <Label x:Name="ArtistLabel"
                       Text="{Binding CurrentFace.Artist, StringFormat='Illustrated by {0}'}"
                       FontSize="11"
                       TextColor="{StaticResource TextSecondary}"
                       IsVisible="{Binding IsArtistVisible}" />

                <Border IsVisible="{Binding HasPurchaseLinks}"
                        Style="{StaticResource CardStyle}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Buy Online"
                               FontSize="16"
                               FontAttributes="Bold" />
                        <VerticalStackLayout x:Name="PurchaseLinksStack" Spacing="6" Padding="0,4,0,0" BindableLayout.ItemsSource="{Binding PurchaseLinks}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="viewmodels:PurchaseLink">
                                    <Label TextType="Html"
                                           Text="{Binding Label}"
                                           FontSize="14"
                                           TextColor="#6CB4E4"
                                           TextDecorations="Underline">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Command="{Binding OpenLinkCommand, Source={RelativeSource AncestorType={x:Type viewmodels:CardDetailViewModel}}}" CommandParameter="{Binding Url}" />
                                        </Label.GestureRecognizers>
                                    </Label>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <uranium:ExpanderView>
                        <uranium:ExpanderView.Header>
                            <Label Text="Format Legality"
                                   FontSize="16"
                                   FontAttributes="Bold" />
                        </uranium:ExpanderView.Header>
                        <VerticalStackLayout x:Name="LegalitiesStack" Spacing="2" Padding="0,8,0,0" BindableLayout.ItemsSource="{Binding Legalities}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="viewmodels:LegalityItem">
                                    <Grid ColumnDefinitions="*,Auto" Padding="0,2">
                                        <Label Text="{Binding Format}" FontSize="13" TextColor="#A0A0A0" />
                                        <Label Text="{Binding StatusText}"
                                               TextColor="{Binding Status, Converter={StaticResource LegalityStatusToColorConverter}}"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               HorizontalTextAlignment="End"
                                               Grid.Column="1" />
                                    </Grid>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </uranium:ExpanderView>
                </Border>

                <Border Style="{StaticResource CardStyle}"
                        IsVisible="{Binding HasRulings}">
                    <uranium:ExpanderView>
                        <uranium:ExpanderView.Header>
                            <Label Text="Rulings"
                                   FontSize="16"
                                   FontAttributes="Bold" />
                        </uranium:ExpanderView.Header>
                        <VerticalStackLayout x:Name="RulingsStack" Spacing="8" Padding="0,8,0,0" BindableLayout.ItemsSource="{Binding Card.Rulings}">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate x:DataType="core:CardRuling">
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="{Binding Date, StringFormat='{0:d}'}" FontSize="11" TextColor="#888888" />
                                        <controls:CardTextView CardText="{Binding Text}"
                                                               TextSize="13"
                                                               TextColor="#E0E0E0"
                                                               SymbolSize="14"
                                                               BackgroundColor="Transparent"
                                                               HorizontalOptions="Fill" />
                                    </VerticalStackLayout>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </uranium:ExpanderView>
                </Border>

                </VerticalStackLayout>
            </controls:SwipeGestureContainer>
        </ScrollView>

        <Label Grid.Row="1"
               Text="{Binding StatusDisplayText}"
               TextColor="{Binding StatusTextColor}"
               FontSize="12"
               Margin="12,4,12,0"
               IsVisible="{Binding HasStatusMessage}"
               HorizontalTextAlignment="Center" />

        <Grid Grid.Row="2"
              BackgroundColor="{StaticResource Surface}"
              Padding="12,8"
              ColumnDefinitions="*,Auto,Auto,Auto"
              ColumnSpacing="8">
            <Grid.GestureRecognizers>
                <SwipeGestureRecognizer Direction="Left" Swiped="OnSwipedLeft" />
                <SwipeGestureRecognizer Direction="Right" Swiped="OnSwipedRight" />
            </Grid.GestureRecognizers>

            <Button Text="Add to Collection"
                    Clicked="OnAddClicked"
                    HeightRequest="40"
                    FontSize="13"
                    Padding="16,0"
                    StyleClass="FilledButton" />

            <Button Grid.Column="1"
                    Text="+ Deck"
                    Clicked="OnAddToDeckClicked"
                    BackgroundColor="{StaticResource CardBackground}"
                    TextColor="{StaticResource Accent}"
                    HeightRequest="40"
                    FontSize="13"
                    Padding="12,0" />

            <Button Grid.Column="2"
                    x:Name="RemoveBtn"
                    Text="Remove"
                    Clicked="OnRemoveClicked"
                    BackgroundColor="{StaticResource ErrorColor}"
                    HeightRequest="40"
                    FontSize="13"
                    Padding="12,0"
                    IsVisible="{Binding IsInCollection}" />

            <Button Grid.Column="3"
                    x:Name="FlipBtn"
                    Text="Flip"
                    Clicked="OnFlipClicked"
                    BackgroundColor="{StaticResource CardBackground}"
                    HeightRequest="40"
                    FontSize="13"
                    Padding="12,0"
                    IsVisible="{Binding HasMultipleFaces}"
                    StyleClass="ElevatedButton" />
        </Grid>

    </Grid>

</ContentPage>