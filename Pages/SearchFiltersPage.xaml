<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
             xmlns:controls="clr-namespace:AetherVault.Controls"
             xmlns:viewmodels="clr-namespace:AetherVault.ViewModels"
             xmlns:models="clr-namespace:AetherVault.Models"
             x:Class="AetherVault.Pages.SearchFiltersPage"
             x:DataType="viewmodels:SearchFiltersViewModel"
             Title="Search Filters"
             BackgroundColor="{StaticResource Background}"
             Shell.PresentationMode="ModalAnimated">

    <ContentPage.Resources>
        <ResourceDictionary>
            <OnIdiom x:Key="HeaderFontSize" x:TypeArguments="x:Double" Phone="16" Tablet="20" Desktop="20" />
            <OnIdiom x:Key="BodyFontSize"   x:TypeArguments="x:Double" Phone="14" Tablet="18" Desktop="18" />
            <OnIdiom x:Key="SmallFontSize"  x:TypeArguments="x:Double" Phone="12" Tablet="16" Desktop="16" />

            <!-- Color filter item template: mana symbol with tap and selected state -->
            <DataTemplate x:Key="ColorFilterItemTemplate" x:DataType="models:ColorFilterItem">
                <Grid WidthRequest="40" HeightRequest="40" Margin="4"
                      Opacity="0.5" Scale="1">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer
                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ToggleColorCommand}"
                            CommandParameter="{Binding Code}" />
                    </Grid.GestureRecognizers>
                    <controls:ManaSymbolView Symbol="{Binding Code}"
                                            InputTransparent="True"
                                            VerticalOptions="Fill"
                                            HorizontalOptions="Fill" />
                    <Grid.Triggers>
                        <DataTrigger TargetType="Grid" Binding="{Binding IsSelected}" Value="True">
                            <DataTrigger.Setters>
                                <Setter Property="Opacity" Value="1" />
                                <Setter Property="Scale" Value="1.1" />
                            </DataTrigger.Setters>
                        </DataTrigger>
                    </Grid.Triggers>
                </Grid>
            </DataTemplate>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0" Padding="16">
            <VerticalStackLayout Spacing="16">

                <!-- Colors -->
                <Border Style="{StaticResource CardStyle}">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Colors" FontSize="{StaticResource HeaderFontSize}" FontAttributes="Bold" />
                        <FlexLayout BindableLayout.ItemsSource="{Binding ColorFilters}"
                                    BindableLayout.ItemTemplate="{StaticResource ColorFilterItemTemplate}"
                                    Wrap="NoWrap" JustifyContent="SpaceEvenly" />
                    </VerticalStackLayout>
                </Border>

                <!-- Card Text / Keywords -->
                <Border Style="{StaticResource CardStyle}">
                    <material:TextField Text="{Binding Keywords, Mode=TwoWay}"
                                        Title="Card Text"
                                        TitleColor="{StaticResource TextSecondary}"
                                        AccentColor="{StaticResource Primary}" />
                </Border>

                <!-- Card Type / Subtype / Supertype -->
                <Border Style="{StaticResource CardStyle}">
                    <VerticalStackLayout Spacing="12">
                        <material:PickerField SelectedIndex="{Binding SelectedTypeIndex, Mode=TwoWay}"
                                               ItemsSource="{Binding TypeOptions}"
                                               Title="Card Type"
                                               TextColor="{StaticResource TextPrimary}"
                                               TitleColor="{StaticResource TextSecondary}"
                                               AccentColor="{StaticResource Primary}" />

                        <material:TextField Text="{Binding Subtype, Mode=TwoWay}"
                                            Title="Subtype"
                                            TitleColor="{StaticResource TextSecondary}"
                                            AccentColor="{StaticResource Primary}" />

                        <material:TextField Text="{Binding Supertype, Mode=TwoWay}"
                                            Title="Supertype"
                                            TitleColor="{StaticResource TextSecondary}"
                                            AccentColor="{StaticResource Primary}" />
                    </VerticalStackLayout>
                </Border>

                <!-- Rarity -->
                <Border Style="{StaticResource CardStyle}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Rarity" FontSize="{StaticResource BodyFontSize}" />
                        <Grid RowDefinitions="Auto,Auto"
                              ColumnDefinitions="*,*"
                              ColumnSpacing="12"
                              RowSpacing="4">
                            <material:CheckBox Grid.Row="0" Grid.Column="0"
                                               IsChecked="{Binding ChkCommon, Mode=TwoWay}"
                                               Text="Common"
                                               Color="{StaticResource Primary}" />
                            <material:CheckBox Grid.Row="0" Grid.Column="1"
                                               IsChecked="{Binding ChkUncommon, Mode=TwoWay}"
                                               Text="Uncommon"
                                               Color="{StaticResource Primary}" />
                            <material:CheckBox Grid.Row="1" Grid.Column="0"
                                               IsChecked="{Binding ChkRare, Mode=TwoWay}"
                                               Text="Rare"
                                               Color="{StaticResource Primary}" />
                            <material:CheckBox Grid.Row="1" Grid.Column="1"
                                               IsChecked="{Binding ChkMythic, Mode=TwoWay}"
                                               Text="Mythic"
                                               Color="{StaticResource Primary}" />
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- CMC Range -->
                <Border Style="{StaticResource CardStyle}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Mana Value (CMC)" FontSize="{StaticResource BodyFontSize}" />
                        <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="8">
                            <VerticalStackLayout>
                                <Label Text="{Binding CmcMinLabel}"
                                       FontSize="{StaticResource SmallFontSize}"
                                       TextColor="{StaticResource TextSecondary}" />
                                <Slider Minimum="0" Maximum="16"
                                        Value="{Binding CmcMin, Mode=TwoWay}"
                                        ThumbColor="{StaticResource Primary}"
                                        MinimumTrackColor="{StaticResource Primary}" />
                            </VerticalStackLayout>
                            <Label Grid.Column="1"
                                   Text="to"
                                   VerticalOptions="End"
                                   Margin="0,0,0,8"
                                   FontSize="{StaticResource BodyFontSize}" />
                            <VerticalStackLayout Grid.Column="2">
                                <Label Text="{Binding CmcMaxLabel}"
                                       FontSize="{StaticResource SmallFontSize}"
                                       TextColor="{StaticResource TextSecondary}" />
                                <Slider Minimum="0" Maximum="16"
                                        Value="{Binding CmcMax, Mode=TwoWay}"
                                        ThumbColor="{StaticResource Primary}"
                                        MinimumTrackColor="{StaticResource Primary}" />
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Border>

                <!-- Power / Toughness -->
                <Border Style="{StaticResource CardStyle}">
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <material:TextField Text="{Binding Power, Mode=TwoWay}"
                                            Title="Power"
                                            Keyboard="Numeric"
                                            TitleColor="{StaticResource TextSecondary}"
                                            AccentColor="{StaticResource Primary}" />
                        <material:TextField Grid.Column="1"
                                            Text="{Binding Toughness, Mode=TwoWay}"
                                            Title="Toughness"
                                            Keyboard="Numeric"
                                            TitleColor="{StaticResource TextSecondary}"
                                            AccentColor="{StaticResource Primary}" />
                    </Grid>
                </Border>

                <!-- Format / Set / Artist -->
                <Border Style="{StaticResource CardStyle}">
                    <VerticalStackLayout Spacing="12">
                        <material:PickerField SelectedIndex="{Binding SelectedFormatIndex, Mode=TwoWay}"
                                              ItemsSource="{Binding FormatOptions}"
                                              Title="Format"
                                              TextColor="{StaticResource TextPrimary}"
                                              TitleColor="{StaticResource TextSecondary}"
                                              AccentColor="{StaticResource Primary}" />

                        <material:PickerField SelectedIndex="{Binding SelectedSetIndex, Mode=TwoWay}"
                                              ItemsSource="{Binding SetList}"
                                              Title="Set"
                                              TextColor="{StaticResource TextPrimary}"
                                              TitleColor="{StaticResource TextSecondary}"
                                              AccentColor="{StaticResource Primary}" />

                        <material:TextField Text="{Binding Artist, Mode=TwoWay}"
                                            Title="Artist"
                                            TitleColor="{StaticResource TextSecondary}"
                                            AccentColor="{StaticResource Primary}" />
                    </VerticalStackLayout>
                </Border>

                <!-- Special Options -->
                <Border Style="{StaticResource CardStyle}">
                    <VerticalStackLayout Spacing="4">
                        <material:CheckBox IsChecked="{Binding ChkPrimarySide, Mode=TwoWay}"
                                           Text="Primary side only"
                                           Color="{StaticResource Primary}"
                                           Margin="0,0,0,8" />
                        <material:CheckBox IsChecked="{Binding ChkNoVariations, Mode=TwoWay}"
                                           Text="Exclude variations"
                                           Color="{StaticResource Primary}"
                                           Margin="0,0,0,8" />
                        <material:CheckBox IsChecked="{Binding ChkIncludeTokens, Mode=TwoWay}"
                                           Text="Include tokens"
                                           Color="{StaticResource Primary}"
                                           Margin="0,0,0,8" />
                        <material:CheckBox IsChecked="{Binding ChkCommanderOnly, Mode=TwoWay}"
                                           Text="Can be commander only"
                                           Color="{StaticResource Primary}"
                                           Margin="0,0,0,8" />
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom buttons -->
        <Grid Grid.Row="1"
              Padding="16,8"
              ColumnDefinitions="*,*,*"
              ColumnSpacing="8"
              BackgroundColor="{StaticResource Surface}">
            <Button Text="Reset"
                    Command="{Binding ResetCommand}"
                    BackgroundColor="{StaticResource CardBackground}" />
            <Button Grid.Column="1"
                    Text="Cancel"
                    Command="{Binding CancelCommand}"
                    BackgroundColor="{StaticResource CardBackground}" />
            <Button Grid.Column="2"
                    Text="Apply"
                    Command="{Binding ApplyCommand}" />
        </Grid>

    </Grid>

</ContentPage>
