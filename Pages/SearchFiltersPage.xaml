<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
             xmlns:controls="clr-namespace:AetherVault.Controls"
             xmlns:viewmodels="clr-namespace:AetherVault.ViewModels"
             xmlns:models="clr-namespace:AetherVault.Models"
             x:Class="AetherVault.Pages.SearchFiltersPage"
             x:DataType="viewmodels:SearchFiltersViewModel"
             Title="Search Filters"
             BackgroundColor="{StaticResource Background}"
             Shell.PresentationMode="ModalAnimated">

    <ContentPage.Resources>
        <ResourceDictionary>
            <OnIdiom x:Key="HeaderFontSize" x:TypeArguments="x:Double" Phone="16" Tablet="20" Desktop="20" />
            <OnIdiom x:Key="BodyFontSize"   x:TypeArguments="x:Double" Phone="14" Tablet="18" Desktop="18" />
            <OnIdiom x:Key="SmallFontSize"  x:TypeArguments="x:Double" Phone="12" Tablet="16" Desktop="16" />

            <!-- Color filter item template: mana symbol with tap and selected state -->
            <DataTemplate x:Key="ColorFilterItemTemplate" x:DataType="models:ColorFilterItem">
                <Grid WidthRequest="40" HeightRequest="40" Margin="4"
                      Opacity="0.5" Scale="1">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer
                            Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ToggleColorCommand}"
                            CommandParameter="{Binding Code}" />
                    </Grid.GestureRecognizers>
                    <controls:ManaSymbolView Symbol="{Binding Code}"
                                            InputTransparent="True"
                                            VerticalOptions="Fill"
                                            HorizontalOptions="Fill" />
                    <Grid.Triggers>
                        <DataTrigger TargetType="Grid" Binding="{Binding IsSelected}" Value="True">
                            <DataTrigger.Setters>
                                <Setter Property="Opacity" Value="1" />
                                <Setter Property="Scale" Value="1.1" />
                            </DataTrigger.Setters>
                        </DataTrigger>
                    </Grid.Triggers>
                </Grid>
            </DataTemplate>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="*,Auto">

        <ScrollView Grid.Row="0" Padding="16">
            <VerticalStackLayout Spacing="16">

                <!-- Sticky summary -->
                <Border Style="{StaticResource CardStyle}">
                    <Grid ColumnDefinitions="*"
                          ColumnSpacing="8">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Refine your search"
                                   FontSize="{StaticResource HeaderFontSize}"
                                   FontAttributes="Bold" />
                            <Label Text="{Binding FiltersSummaryText}"
                                   FontSize="{StaticResource SmallFontSize}"
                                   TextColor="{StaticResource TextSecondary}"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="2" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- Text & type section -->
                <Border Style="{StaticResource CardStyle}">
                    <Grid RowDefinitions="Auto,Auto">
                        <Grid Row="0"
                              ColumnDefinitions="*,Auto"
                              ColumnSpacing="8">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Text &amp; type"
                                       FontSize="{StaticResource BodyFontSize}"
                                       FontAttributes="Bold" />
                                <Label Text="Name, rules text and card types"
                                       FontSize="{StaticResource SmallFontSize}"
                                       TextColor="{StaticResource TextSecondary}" />
                            </VerticalStackLayout>
                            <Grid Grid.Column="1"
                                  VerticalOptions="Center">
                                <Label FontSize="{StaticResource SmallFontSize}"
                                       TextColor="{StaticResource TextSecondary}"
                                       Text="{Binding IsTextSectionExpanded, Converter={StaticResource BoolToChevronConverter}}" />
                            </Grid>
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleTextSectionCommand}" />
                            </Grid.GestureRecognizers>
                        </Grid>

                        <VerticalStackLayout Grid.Row="1"
                                             Spacing="12"
                                             IsVisible="{Binding IsTextSectionExpanded}">
                            <material:TextField Text="{Binding Keywords, Mode=TwoWay}"
                                                Title="Card text or rules"
                                                TitleColor="{StaticResource TextSecondary}"
                                                AccentColor="{StaticResource Primary}" />

                            <VerticalStackLayout Spacing="12">
                                <material:PickerField SelectedIndex="{Binding SelectedTypeIndex, Mode=TwoWay}"
                                                       ItemsSource="{Binding TypeOptions}"
                                                       Title="Card type"
                                                       TextColor="{StaticResource TextPrimary}"
                                                       TitleColor="{StaticResource TextSecondary}"
                                                       AccentColor="{StaticResource Primary}" />

                                <material:TextField Text="{Binding Subtype, Mode=TwoWay}"
                                                    Title="Subtype"
                                                    TitleColor="{StaticResource TextSecondary}"
                                                    AccentColor="{StaticResource Primary}" />

                                <material:TextField Text="{Binding Supertype, Mode=TwoWay}"
                                                    Title="Supertype"
                                                    TitleColor="{StaticResource TextSecondary}"
                                                    AccentColor="{StaticResource Primary}" />
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- Colors & rarity section -->
                <Border Style="{StaticResource CardStyle}">
                    <Grid RowDefinitions="Auto,Auto">
                        <Grid Row="0"
                              ColumnDefinitions="*,Auto"
                              ColumnSpacing="8">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Colors &amp; rarity"
                                       FontSize="{StaticResource BodyFontSize}"
                                       FontAttributes="Bold" />
                                <Label Text="Filter by mana colors and rarity"
                                       FontSize="{StaticResource SmallFontSize}"
                                       TextColor="{StaticResource TextSecondary}" />
                            </VerticalStackLayout>
                            <Grid Grid.Column="1"
                                  VerticalOptions="Center">
                                <Label FontSize="{StaticResource SmallFontSize}"
                                       TextColor="{StaticResource TextSecondary}"
                                       Text="{Binding IsColorSectionExpanded, Converter={StaticResource BoolToChevronConverter}}" />
                            </Grid>
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleColorSectionCommand}" />
                            </Grid.GestureRecognizers>
                        </Grid>

                        <VerticalStackLayout Grid.Row="1"
                                             Spacing="12"
                                             IsVisible="{Binding IsColorSectionExpanded}">
                            <!-- Colors -->
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Colors"
                                       FontSize="{StaticResource SmallFontSize}"
                                       TextColor="{StaticResource TextSecondary}" />
                                <FlexLayout BindableLayout.ItemsSource="{Binding ColorFilters}"
                                            BindableLayout.ItemTemplate="{StaticResource ColorFilterItemTemplate}"
                                            Wrap="Wrap"
                                            JustifyContent="Center" />
                            </VerticalStackLayout>

                            <!-- Rarity -->
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Rarity"
                                       FontSize="{StaticResource SmallFontSize}"
                                       TextColor="{StaticResource TextSecondary}" />
                                <Grid RowDefinitions="Auto,Auto"
                                      ColumnDefinitions="*,*"
                                      ColumnSpacing="12"
                                      RowSpacing="8">
                                    <material:CheckBox Grid.Row="0" Grid.Column="0"
                                                       IsChecked="{Binding ChkCommon, Mode=TwoWay}"
                                                       Text="Common"
                                                       HorizontalOptions="Fill"
                                                       Color="{StaticResource Primary}" />
                                    <material:CheckBox Grid.Row="0" Grid.Column="1"
                                                       IsChecked="{Binding ChkUncommon, Mode=TwoWay}"
                                                       Text="Uncommon"
                                                       HorizontalOptions="Fill"
                                                       Color="{StaticResource Primary}" />
                                    <material:CheckBox Grid.Row="1" Grid.Column="0"
                                                       IsChecked="{Binding ChkRare, Mode=TwoWay}"
                                                       Text="Rare"
                                                       HorizontalOptions="Fill"
                                                       Color="{StaticResource Primary}" />
                                    <material:CheckBox Grid.Row="1" Grid.Column="1"
                                                       IsChecked="{Binding ChkMythic, Mode=TwoWay}"
                                                       Text="Mythic"
                                                       HorizontalOptions="Fill"
                                                       Color="{StaticResource Primary}" />
                                </Grid>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- Stats section -->
                <Border Style="{StaticResource CardStyle}">
                    <Grid RowDefinitions="Auto,Auto">
                        <Grid Row="0"
                              ColumnDefinitions="*,Auto"
                              ColumnSpacing="8">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Stats"
                                       FontSize="{StaticResource BodyFontSize}"
                                       FontAttributes="Bold" />
                                <Label Text="Mana value, power and toughness"
                                       FontSize="{StaticResource SmallFontSize}"
                                       TextColor="{StaticResource TextSecondary}" />
                            </VerticalStackLayout>
                            <Grid Grid.Column="1"
                                  VerticalOptions="Center">
                                <Label FontSize="{StaticResource SmallFontSize}"
                                       TextColor="{StaticResource TextSecondary}"
                                       Text="{Binding IsStatsSectionExpanded, Converter={StaticResource BoolToChevronConverter}}" />
                            </Grid>
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleStatsSectionCommand}" />
                            </Grid.GestureRecognizers>
                        </Grid>

                        <VerticalStackLayout Grid.Row="1"
                                             Spacing="12"
                                             IsVisible="{Binding IsStatsSectionExpanded}">
                            <!-- CMC Range -->
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Mana value (CMC)"
                                       FontSize="{StaticResource SmallFontSize}"
                                       TextColor="{StaticResource TextSecondary}" />
                                <Grid ColumnDefinitions="*,Auto,*"
                                      ColumnSpacing="8">
                                    <VerticalStackLayout>
                                        <Label Text="{Binding CmcMinLabel}"
                                               FontSize="{StaticResource SmallFontSize}"
                                               TextColor="{StaticResource TextSecondary}" />
                                        <Slider Minimum="0" Maximum="16"
                                                Value="{Binding CmcMin, Mode=TwoWay}"
                                                ThumbColor="{StaticResource Primary}"
                                                MinimumTrackColor="{StaticResource Primary}" />
                                    </VerticalStackLayout>
                                    <Label Grid.Column="1"
                                           Text="to"
                                           VerticalOptions="End"
                                           Margin="0,0,0,8"
                                           FontSize="{StaticResource BodyFontSize}" />
                                    <VerticalStackLayout Grid.Column="2">
                                        <Label Text="{Binding CmcMaxLabel}"
                                               FontSize="{StaticResource SmallFontSize}"
                                               TextColor="{StaticResource TextSecondary}" />
                                        <Slider Minimum="0" Maximum="16"
                                                Value="{Binding CmcMax, Mode=TwoWay}"
                                                ThumbColor="{StaticResource Primary}"
                                                MinimumTrackColor="{StaticResource Primary}" />
                                    </VerticalStackLayout>
                                </Grid>
                            </VerticalStackLayout>

                            <!-- Power / Toughness -->
                            <VerticalStackLayout Spacing="12">
                                <material:TextField Text="{Binding Power, Mode=TwoWay}"
                                                    Title="Power"
                                                    Keyboard="Numeric"
                                                    TitleColor="{StaticResource TextSecondary}"
                                                    AccentColor="{StaticResource Primary}" />
                                <material:TextField Text="{Binding Toughness, Mode=TwoWay}"
                                                    Title="Toughness"
                                                    Keyboard="Numeric"
                                                    TitleColor="{StaticResource TextSecondary}"
                                                    AccentColor="{StaticResource Primary}" />
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- Format, set & artist section -->
                <Border Style="{StaticResource CardStyle}">
                    <Grid RowDefinitions="Auto,Auto">
                        <Grid Row="0"
                              ColumnDefinitions="*,Auto"
                              ColumnSpacing="8">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Format, set &amp; artist"
                                       FontSize="{StaticResource BodyFontSize}"
                                       FontAttributes="Bold" />
                                <Label Text="Format legality, printings and artist"
                                       FontSize="{StaticResource SmallFontSize}"
                                       TextColor="{StaticResource TextSecondary}" />
                            </VerticalStackLayout>
                            <Grid Grid.Column="1"
                                  VerticalOptions="Center">
                                <Label FontSize="{StaticResource SmallFontSize}"
                                       TextColor="{StaticResource TextSecondary}"
                                       Text="{Binding IsFormatSectionExpanded, Converter={StaticResource BoolToChevronConverter}}" />
                            </Grid>
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleFormatSectionCommand}" />
                            </Grid.GestureRecognizers>
                        </Grid>

                        <VerticalStackLayout Grid.Row="1"
                                             Spacing="12"
                                             IsVisible="{Binding IsFormatSectionExpanded}">
                            <material:PickerField SelectedIndex="{Binding SelectedFormatIndex, Mode=TwoWay}"
                                                  ItemsSource="{Binding FormatOptions}"
                                                  Title="Format"
                                                  TextColor="{StaticResource TextPrimary}"
                                                  TitleColor="{StaticResource TextSecondary}"
                                                  AccentColor="{StaticResource Primary}" />

                            <material:PickerField SelectedIndex="{Binding SelectedSetIndex, Mode=TwoWay}"
                                                  ItemsSource="{Binding SetList}"
                                                  Title="Set"
                                                  TextColor="{StaticResource TextPrimary}"
                                                  TitleColor="{StaticResource TextSecondary}"
                                                  AccentColor="{StaticResource Primary}" />

                            <material:TextField Text="{Binding Artist, Mode=TwoWay}"
                                                Title="Artist"
                                                TitleColor="{StaticResource TextSecondary}"
                                                AccentColor="{StaticResource Primary}" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- Special options section -->
                <Border Style="{StaticResource CardStyle}">
                    <Grid RowDefinitions="Auto,Auto">
                        <Grid Row="0"
                              ColumnDefinitions="*,Auto"
                              ColumnSpacing="8">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Special options"
                                       FontSize="{StaticResource BodyFontSize}"
                                       FontAttributes="Bold" />
                                <Label Text="Sides, variations, tokens and commander"
                                       FontSize="{StaticResource SmallFontSize}"
                                       TextColor="{StaticResource TextSecondary}" />
                            </VerticalStackLayout>
                            <Grid Grid.Column="1"
                                  VerticalOptions="Center">
                                <Label FontSize="{StaticResource SmallFontSize}"
                                       TextColor="{StaticResource TextSecondary}"
                                       Text="{Binding IsSpecialSectionExpanded, Converter={StaticResource BoolToChevronConverter}}" />
                            </Grid>
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleSpecialSectionCommand}" />
                            </Grid.GestureRecognizers>
                        </Grid>

                        <VerticalStackLayout Grid.Row="1"
                                             Spacing="8"
                                             IsVisible="{Binding IsSpecialSectionExpanded}">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="Primary side only"
                                       VerticalOptions="Center"
                                       FontSize="{StaticResource SmallFontSize}"
                                       TextColor="{StaticResource TextPrimary}" />
                                <material:CheckBox Grid.Column="1"
                                                   IsChecked="{Binding ChkPrimarySide, Mode=TwoWay}"
                                                   Color="{StaticResource Primary}" />
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="Exclude variations"
                                       VerticalOptions="Center"
                                       FontSize="{StaticResource SmallFontSize}"
                                       TextColor="{StaticResource TextPrimary}" />
                                <material:CheckBox Grid.Column="1"
                                                   IsChecked="{Binding ChkNoVariations, Mode=TwoWay}"
                                                   Color="{StaticResource Primary}" />
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="Include tokens"
                                       VerticalOptions="Center"
                                       FontSize="{StaticResource SmallFontSize}"
                                       TextColor="{StaticResource TextPrimary}" />
                                <material:CheckBox Grid.Column="1"
                                                   IsChecked="{Binding ChkIncludeTokens, Mode=TwoWay}"
                                                   Color="{StaticResource Primary}" />
                            </Grid>
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="Can be commander only"
                                       VerticalOptions="Center"
                                       FontSize="{StaticResource SmallFontSize}"
                                       TextColor="{StaticResource TextPrimary}" />
                                <material:CheckBox Grid.Column="1"
                                                   IsChecked="{Binding ChkCommanderOnly, Mode=TwoWay}"
                                                   Color="{StaticResource Primary}" />
                            </Grid>
                        </VerticalStackLayout>
                    </Grid>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom buttons -->
        <Grid Grid.Row="1"
              Padding="16,8"
              ColumnDefinitions="Auto,*"
              ColumnSpacing="12"
              BackgroundColor="{StaticResource Surface}">
            <Button Text="Reset"
                    Command="{Binding ResetCommand}"
                    BackgroundColor="{StaticResource CardBackground}" />
            <Button Grid.Column="1"
                    Text="Apply filters"
                    Command="{Binding ApplyCommand}" />
        </Grid>

    </Grid>

</ContentPage>
