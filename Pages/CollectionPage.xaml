<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:fa="clr-namespace:UraniumUI.Icons.FontAwesome;assembly=UraniumUI.Icons.FontAwesome"
             xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
             xmlns:controls="clr-namespace:AetherVault.Controls"
             xmlns:vm="clr-namespace:AetherVault.ViewModels"
             x:Class="AetherVault.Pages.CollectionPage"
             x:DataType="vm:CollectionViewModel"
             Title="Collection"
             BackgroundColor="{StaticResource Background}">

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Header + summary card -->
        <Border Grid.Row="0"
                Style="{StaticResource CardStyle}"
                Margin="8,8,8,4">
            <VerticalStackLayout Spacing="8">

                <!-- Title row -->
                <Grid ColumnDefinitions="*,Auto"
                      ColumnSpacing="12">
                    <VerticalStackLayout Spacing="4">
                        <Label x:Name="CollectionTitle"
                               Text="My Collection"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{StaticResource TextPrimary}" />

                        <HorizontalStackLayout Spacing="12">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Total cards"
                                       FontSize="11"
                                       TextColor="{StaticResource TextSecondary}" />
                                <Label Text="{Binding TotalCards}"
                                       FontSize="15"
                                       FontAttributes="Bold" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Spacing="2">
                                <Label Text="Unique"
                                       FontSize="11"
                                       TextColor="{StaticResource TextSecondary}" />
                                <Label Text="{Binding UniqueCards}"
                                       FontSize="15"
                                       FontAttributes="Bold" />
                            </VerticalStackLayout>
                        </HorizontalStackLayout>

                        <HorizontalStackLayout Spacing="8">
                            <Label x:Name="CollectionStatus"
                                   Text="{Binding StatusDisplayText}"
                                   FontSize="12"
                                   VerticalOptions="Center"
                                   TextColor="{Binding StatusTextColor}" />
                            <HorizontalStackLayout IsVisible="{Binding IsImportingPrices}"
                                                   Spacing="4"
                                                   VerticalOptions="Center">
                                <ActivityIndicator IsRunning="{Binding IsImportingPrices}"
                                                   HeightRequest="12"
                                                   WidthRequest="12"
                                                   Color="{StaticResource TextSecondary}" />
                                <Label Text="Syncing Prices..."
                                       FontSize="10"
                                       TextColor="{StaticResource TextSecondary}"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="1"
                                         Spacing="8"
                                         HorizontalOptions="End"
                                         VerticalOptions="Center">
                        <ActivityIndicator x:Name="CollectionLoading"
                                           IsRunning="{Binding IsBusy}"
                                           IsVisible="{Binding IsBusy}"
                                           HeightRequest="20"
                                           WidthRequest="20"
                                           Color="{StaticResource Primary}" />
                        <Button Text="{Binding ViewModeButtonText}"
                                Command="{Binding ToggleViewModeCommand}"
                                BackgroundColor="{StaticResource CardBackground}"
                                HeightRequest="36"
                                Padding="10,0"
                                FontSize="13"
                                StyleClass="ElevatedButton"
                                ToolTipProperties.Text="{Binding ViewModeToolTip}" />
                    </VerticalStackLayout>
                </Grid>

                <!-- Divider -->
                <BoxView HeightRequest="1"
                         Color="{StaticResource Surface}"
                         Margin="0,0" />

                <!-- Action button row -->
                <Grid ColumnDefinitions="*,*,*,*">

                    <!-- Import -->
                    <VerticalStackLayout Grid.Column="0"
                                         HorizontalOptions="Center"
                                         Spacing="3"
                                         Padding="4,2">
                        <VerticalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ImportCollectionCommand}" />
                        </VerticalStackLayout.GestureRecognizers>
                        <Label FontFamily="FASolid"
                               Text="{x:Static fa:Solid.FileImport}"
                               FontSize="20"
                               HorizontalOptions="Center"
                               TextColor="{StaticResource Primary}" />
                        <Label Text="Import"
                               FontSize="11"
                               HorizontalOptions="Center"
                               TextColor="{StaticResource TextSecondary}" />
                    </VerticalStackLayout>

                    <!-- Export -->
                    <VerticalStackLayout Grid.Column="1"
                                         HorizontalOptions="Center"
                                         Spacing="3"
                                         Padding="4,2">
                        <VerticalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding ExportCollectionCommand}" />
                        </VerticalStackLayout.GestureRecognizers>
                        <Label FontFamily="FASolid"
                               Text="{x:Static fa:Solid.FileExport}"
                               FontSize="20"
                               HorizontalOptions="Center"
                               TextColor="{StaticResource Primary}" />
                        <Label Text="Export"
                               FontSize="11"
                               HorizontalOptions="Center"
                               TextColor="{StaticResource TextSecondary}" />
                    </VerticalStackLayout>

                    <!-- Refresh -->
                    <VerticalStackLayout Grid.Column="2"
                                         HorizontalOptions="Center"
                                         Spacing="3"
                                         Padding="4,2">
                        <VerticalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding RefreshCommand}" />
                        </VerticalStackLayout.GestureRecognizers>
                        <Label FontFamily="FASolid"
                               Text="{x:Static fa:Solid.ArrowsRotate}"
                               FontSize="20"
                               HorizontalOptions="Center"
                               TextColor="{StaticResource Primary}" />
                        <Label Text="Refresh"
                               FontSize="11"
                               HorizontalOptions="Center"
                               TextColor="{StaticResource TextSecondary}" />
                    </VerticalStackLayout>

                    <!-- Clear -->
                    <VerticalStackLayout Grid.Column="3"
                                         HorizontalOptions="Center"
                                         Spacing="3"
                                         Padding="4,2">
                        <VerticalStackLayout.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnClearCollectionClicked" />
                        </VerticalStackLayout.GestureRecognizers>
                        <Label FontFamily="FASolid"
                               Text="{x:Static fa:Solid.TrashCan}"
                               FontSize="20"
                               HorizontalOptions="Center"
                               TextColor="#CF6679" />
                        <Label Text="Clear"
                               FontSize="11"
                               HorizontalOptions="Center"
                               TextColor="{StaticResource TextSecondary}" />
                    </VerticalStackLayout>

                </Grid>

            </VerticalStackLayout>
        </Border>

        <!-- Filter + Sort Row -->
        <Border Grid.Row="1"
                Style="{StaticResource CardStyle}"
                Margin="8,0,8,4">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="8">
                <material:TextField Title="Filter collection..."
                                    Text="{Binding FilterText, Mode=TwoWay}"
                                    TitleColor="{StaticResource TextSecondary}"
                                    AccentColor="{StaticResource Primary}"
                                    AllowClear="True" />
                <material:PickerField Grid.Column="1"
                                      Title="Sort"
                                      ItemsSource="{Binding SortModeOptions}"
                                      SelectedIndex="{Binding SortModeIndex, Mode=TwoWay}"
                                      TextColor="{StaticResource TextPrimary}"
                                      TitleColor="{StaticResource TextSecondary}"
                                      AccentColor="{StaticResource Primary}"
                                      WidthRequest="130" />
            </Grid>
        </Border>

        <!-- Content area: same pattern as SearchPage — grid and empty state always in tree, visibility toggled (no add/remove). -->
        <Grid x:Name="CollectionContentArea"
              Grid.Row="2"
              BackgroundColor="{StaticResource Background}">
            <Grid x:Name="CollectionEmptyState"
                  IsVisible="{Binding IsCollectionEmpty}"
                  BackgroundColor="{StaticResource Background}"
                  VerticalOptions="Fill"
                  HorizontalOptions="Fill"
                  MinimumHeightRequest="200">
                <VerticalStackLayout VerticalOptions="Center"
                                     HorizontalOptions="Center"
                                     Spacing="8">
                    <Label FontFamily="FASolid"
                           Text="{x:Static fa:Solid.BoxArchive}"
                           FontSize="44"
                           TextColor="{StaticResource TextSecondary}"
                           HorizontalOptions="Center" />
                    <Label Text="Your collection is empty"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}"
                           HorizontalOptions="Center" />
                    <Label Text="Search for cards and long-press to add them"
                           FontSize="13"
                           TextColor="{StaticResource TextSecondary}"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Grid>
            <controls:CardGrid x:Name="CollectionGrid"
                               IsVisible="{Binding IsCollectionEmpty, Converter={StaticResource InvertedBoolConverter}}"
                               Scrolled="OnCollectionScrolled"
                               UseCompactGrid="True" />
        </Grid>

    </Grid>

</ContentPage>
