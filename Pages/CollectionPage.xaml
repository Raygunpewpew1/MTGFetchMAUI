<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:fa="clr-namespace:UraniumUI.Icons.FontAwesome;assembly=UraniumUI.Icons.FontAwesome"
             xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
             xmlns:controls="clr-namespace:AetherVault.Controls"
             xmlns:vm="clr-namespace:AetherVault.ViewModels"
             x:Class="AetherVault.Pages.CollectionPage"
             x:DataType="vm:CollectionViewModel"
             Title="Collection"
             BackgroundColor="{StaticResource Background}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <toolkit:InvertedBoolConverter x:Key="InvertedBoolConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Import"
                     Command="{Binding ImportCollectionCommand}">
            <ToolbarItem.IconImageSource>
                <FontImageSource FontFamily="FASolid"
                                 Glyph="{x:Static fa:Solid.FileImport}"
                                 Size="24"
                                 Color="{StaticResource TextPrimary}" />
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
        <ToolbarItem Text="Export"
                     Command="{Binding ExportCollectionCommand}">
            <ToolbarItem.IconImageSource>
                <FontImageSource FontFamily="FASolid"
                                 Glyph="{x:Static fa:Solid.FileExport}"
                                 Size="24"
                                 Color="{StaticResource TextPrimary}" />
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
        <ToolbarItem Text="Refresh"
                     Command="{Binding RefreshCommand}">
            <ToolbarItem.IconImageSource>
                <FontImageSource FontFamily="FASolid"
                                 Glyph="{x:Static fa:Solid.ArrowsRotate}"
                                 Size="24"
                                 Color="{StaticResource TextPrimary}" />
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
        <ToolbarItem Text="Clear"
                     Clicked="OnClearCollectionClicked">
            <ToolbarItem.IconImageSource>
                <FontImageSource FontFamily="FASolid"
                                 Glyph="{x:Static fa:Solid.TrashCan}"
                                 Size="24"
                                 Color="{StaticResource TextPrimary}" />
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,Auto,*">

        <!-- Header + summary card -->
        <Border Grid.Row="0"
                Style="{StaticResource CardStyle}"
                Margin="8,8,8,4">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="12">
                <VerticalStackLayout Spacing="4">
                    <Label x:Name="CollectionTitle"
                           Text="My Collection"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}" />

                    <HorizontalStackLayout Spacing="12">
                        <VerticalStackLayout Spacing="2">
                            <Label Text="Total cards"
                                   FontSize="11"
                                   TextColor="{StaticResource TextSecondary}" />
                            <Label Text="{Binding TotalCards}"
                                   FontSize="15"
                                   FontAttributes="Bold" />
                        </VerticalStackLayout>

                        <VerticalStackLayout Spacing="2">
                            <Label Text="Unique"
                                   FontSize="11"
                                   TextColor="{StaticResource TextSecondary}" />
                            <Label Text="{Binding UniqueCards}"
                                   FontSize="15"
                                   FontAttributes="Bold" />
                        </VerticalStackLayout>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="8">
                        <Label x:Name="CollectionStatus"
                               Text="{Binding StatusDisplayText}"
                               FontSize="12"
                               VerticalOptions="Center"
                               TextColor="{Binding StatusTextColor}" />
                        <HorizontalStackLayout IsVisible="{Binding IsImportingPrices}"
                                               Spacing="4"
                                               VerticalOptions="Center">
                            <ActivityIndicator IsRunning="{Binding IsImportingPrices}"
                                               HeightRequest="12"
                                               WidthRequest="12"
                                               Color="{StaticResource TextSecondary}" />
                            <Label Text="Syncing Prices..."
                                   FontSize="10"
                                   TextColor="{StaticResource TextSecondary}"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1"
                                     Spacing="8"
                                     HorizontalOptions="End"
                                     VerticalOptions="Center">
                    <ActivityIndicator x:Name="CollectionLoading"
                                       IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}"
                                       HeightRequest="20"
                                       WidthRequest="20"
                                       Color="{StaticResource Primary}" />
                    <Button Text="{Binding ViewModeButtonText}"
                            Command="{Binding ToggleViewModeCommand}"
                            BackgroundColor="{StaticResource CardBackground}"
                            HeightRequest="36"
                            WidthRequest="36"
                            Padding="0"
                            FontSize="18"
                            StyleClass="ElevatedButton" />
                </VerticalStackLayout>
            </Grid>
        </Border>

        <!-- Filter + Sort Row -->
        <Border Grid.Row="1"
                Style="{StaticResource CardStyle}"
                Margin="8,0,8,4">
            <Grid ColumnDefinitions="*,Auto"
                  ColumnSpacing="8">
                <material:TextField Title="Filter collection..."
                                    Text="{Binding FilterText, Mode=TwoWay}"
                                    TitleColor="{StaticResource TextSecondary}"
                                    AccentColor="{StaticResource Primary}"
                                    AllowClear="True" />
                <material:PickerField Grid.Column="1"
                                      Title="Sort"
                                      ItemsSource="{Binding SortModeOptions}"
                                      SelectedIndex="{Binding SortModeIndex, Mode=TwoWay}"
                                      TextColor="{StaticResource TextPrimary}"
                                      TitleColor="{StaticResource TextSecondary}"
                                      AccentColor="{StaticResource Primary}"
                                      WidthRequest="130" />
            </Grid>
        </Border>

        <!-- Content area: when empty only empty state is in tree (no Skia). Grid is added/removed in code. -->
        <Grid x:Name="CollectionContentArea"
              Grid.Row="2"
              BackgroundColor="{StaticResource Background}">
            <Grid x:Name="CollectionEmptyState"
                  IsVisible="{Binding IsCollectionEmpty}"
                  BackgroundColor="{StaticResource Background}"
                  VerticalOptions="Fill"
                  HorizontalOptions="Fill"
                  MinimumHeightRequest="200">
                <VerticalStackLayout VerticalOptions="Center"
                                     HorizontalOptions="Center"
                                     Spacing="8">
                    <Label FontFamily="FASolid"
                           Text="{x:Static fa:Solid.BoxArchive}"
                           FontSize="44"
                           TextColor="{StaticResource TextSecondary}"
                           HorizontalOptions="Center" />
                    <Label Text="Your collection is empty"
                           FontSize="18"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}"
                           HorizontalOptions="Center" />
                    <Label Text="Search for cards and long-press to add them"
                           FontSize="13"
                           TextColor="{StaticResource TextSecondary}"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </Grid>
            <controls:CardGrid x:Name="CollectionGrid"
                               Scrolled="OnCollectionScrolled"
                               UseCompactGrid="True" />
        </Grid>

    </Grid>

</ContentPage>
