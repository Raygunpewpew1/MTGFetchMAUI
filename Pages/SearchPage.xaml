<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:controls="clr-namespace:AetherVault.Controls"
             xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
             x:Class="AetherVault.Pages.SearchPage"
             x:Name="SearchPageRoot"
             Title="Search"
             BackgroundColor="{StaticResource Background}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <toolkit:InvertedBoolConverter x:Key="InvertedBoolConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <!-- Search + Status Card -->
        <Border Grid.Row="0"
                Style="{StaticResource CardStyle}"
                Margin="8,8,8,4">
            <Grid RowDefinitions="Auto,Auto"
                  ColumnDefinitions="*,Auto,Auto"
                  ColumnSpacing="8">

                <!-- Search Bar -->
                <material:TextField Grid.Row="0"
                                    Grid.Column="0"
                                    x:Name="SearchEntry"
                                    Title="Search cards..."
                                    Text="{Binding SearchText, Mode=TwoWay}"
                                    ReturnCommand="{Binding SearchCommand}"
                                    TextColor="{StaticResource TextPrimary}"
                                    TitleColor="{StaticResource TextSecondary}"
                                    AccentColor="{StaticResource Primary}"
                                    AllowClear="True" />

                <Button Grid.Row="0"
                        Grid.Column="1"
                        Text="{Binding FiltersButtonText}"
                        Command="{Binding GoToFiltersCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBoolConverter}}"
                        BackgroundColor="{StaticResource CardBackground}"
                        HeightRequest="44"
                        Padding="12,0"
                        StyleClass="ElevatedButton" />

                <Button Grid.Row="0"
                        Grid.Column="2"
                        Text="{Binding ViewModeButtonText}"
                        Command="{Binding ToggleViewModeCommand}"
                        BackgroundColor="{StaticResource CardBackground}"
                        HeightRequest="44"
                        WidthRequest="44"
                        Padding="0"
                        FontSize="18"
                        StyleClass="ElevatedButton" />

                <!-- Status Bar -->
                <Label Grid.Row="1"
                       Grid.Column="0"
                       x:Name="StatusLabel"
                       Text="{Binding StatusDisplayText}"
                       TextColor="{Binding StatusTextColor}"
                       FontSize="12"
                       VerticalOptions="Center" />

                <HorizontalStackLayout Grid.Row="1"
                                       Grid.Column="1"
                                       IsVisible="{Binding IsImportingPrices}"
                                       Spacing="4"
                                       VerticalOptions="Center"
                                       Margin="0,0,8,0">
                    <ActivityIndicator IsRunning="{Binding IsImportingPrices}"
                                       HeightRequest="12"
                                       WidthRequest="12"
                                       Color="{StaticResource TextSecondary}" />
                    <Label Text="Syncing Prices..."
                           TextColor="{StaticResource TextSecondary}"
                           FontSize="10"
                           VerticalOptions="Center" />
                </HorizontalStackLayout>

                <ActivityIndicator Grid.Row="1"
                                   Grid.Column="2"
                                   x:Name="LoadingIndicator"
                                   IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   HeightRequest="20"
                                   WidthRequest="20"
                                   Color="{StaticResource Primary}" />

            </Grid>
        </Border>

        <!-- Card Grid -->
        <controls:CardGrid Grid.Row="1"
                           x:Name="CardGrid"
                           Scrolled="OnGridScrolled"
                           IsDragEnabled="False" />

        <!-- Empty State -->
        <VerticalStackLayout Grid.Row="1"
                             IsVisible="{Binding IsEmpty}"
                             VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="8">
            <Label Text="&#x1F50D;"
                   FontSize="48"
                   HorizontalOptions="Center" />
            <Label Text="No cards found"
                   FontSize="18"
                   FontAttributes="Bold"
                   TextColor="{StaticResource TextPrimary}"
                   HorizontalOptions="Center" />
            <Label Text="Try a different search or adjust your filters"
                   FontSize="13"
                   TextColor="{StaticResource TextSecondary}"
                   HorizontalOptions="Center"
                   HorizontalTextAlignment="Center" />
        </VerticalStackLayout>

    </Grid>

</ContentPage>
