<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:controls="clr-namespace:AetherVault.Controls"
             xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
             xmlns:fa="clr-namespace:UraniumUI.Icons.FontAwesome;assembly=UraniumUI.Icons.FontAwesome"
             x:Class="AetherVault.Pages.SearchPage"
             x:Name="SearchPageRoot"
             Title="Search"
             BackgroundColor="{StaticResource Background}">

    <Grid>
        <Grid RowDefinitions="Auto,*">

            <!-- Search + status + active filters -->
            <Border Grid.Row="0"
                    Style="{StaticResource CardStyle}"
                    Margin="8,8,8,4">
                <Grid RowDefinitions="Auto,Auto,Auto"
                      ColumnDefinitions="*,Auto,Auto"
                      ColumnSpacing="8">

                    <controls:CardSearchBar Grid.Row="0"
                                            Grid.ColumnSpan="3"
                                            x:Name="SearchBar"
                                            FiltersCommand="{Binding GoToFiltersCommand}" />

                    <Label Grid.Row="1"
                           Grid.Column="0"
                           x:Name="StatusLabel"
                           Text="{Binding StatusDisplayText}"
                           TextColor="{Binding StatusTextColor}"
                           FontSize="12"
                           VerticalOptions="Center" />

                    <HorizontalStackLayout Grid.Row="1"
                                           Grid.Column="1"
                                           IsVisible="{Binding IsImportingPrices}"
                                           Spacing="4"
                                           VerticalOptions="Center"
                                           Margin="0,0,8,0">
                        <ActivityIndicator IsRunning="{Binding IsImportingPrices}"
                                           HeightRequest="12"
                                           WidthRequest="12"
                                           Color="{StaticResource TextSecondary}" />
                        <Label Text="Syncing Prices..."
                               TextColor="{StaticResource TextSecondary}"
                               FontSize="10"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <ActivityIndicator Grid.Row="1"
                                       Grid.Column="2"
                                       x:Name="LoadingIndicator"
                                       IsRunning="{Binding IsBusy}"
                                       IsVisible="{Binding IsBusy}"
                                       HeightRequest="20"
                                       WidthRequest="20"
                                       Color="{StaticResource Primary}" />

                    <Grid Grid.Row="2"
                          Grid.ColumnSpan="3"
                          ColumnDefinitions="*,Auto"
                          ColumnSpacing="10"
                          Margin="0,6,0,0"
                          IsVisible="{Binding HasNonTextFilters}">
                        <Label Text="{Binding FiltersSummaryText}"
                               FontSize="11"
                               TextColor="{StaticResource TextSecondary}"
                               VerticalOptions="Center"
                               LineBreakMode="TailTruncation" />
                        <Button Grid.Column="1"
                                Text="Clear"
                                Command="{Binding ClearCommand}"
                                BackgroundColor="{StaticResource Surface}"
                                TextColor="{StaticResource TextSecondary}"
                                Padding="12,6"
                                FontSize="12"
                                CornerRadius="8" />
                    </Grid>
                </Grid>
            </Border>

            <controls:CardGrid Grid.Row="1"
                               x:Name="CardGrid"
                               IsVisible="{Binding IsEmpty, Converter={StaticResource InvertedBool}}"
                               Scrolled="OnGridScrolled"
                               IsDragEnabled="False" />

            <controls:EmptyStateView Grid.Row="1"
                                     IsVisible="{Binding IsEmpty}"
                                     IconGlyph="{x:Static fa:Solid.MagnifyingGlass}"
                                     Message="No cards found"
                                     SecondaryMessage="Try a different search or adjust your filters" />

        </Grid>

        <Border x:Name="EasterEggTapArea"
                VerticalOptions="Start"
                HorizontalOptions="End"
                Margin="0,56,24,0"
                WidthRequest="96"
                HeightRequest="96"
                BackgroundColor="#01000000"
                InputTransparent="False">
            <Border.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnEasterEggTap" NumberOfTapsRequired="1" />
            </Border.GestureRecognizers>
        </Border>
    </Grid>

</ContentPage>
