<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AetherVault.Pages.AddToDeckPage"
             BackgroundColor="{StaticResource Background}">

    <Border BackgroundColor="{StaticResource Surface}"
            StrokeThickness="1"
            Stroke="{StaticResource Accent}"
            StrokeShape="RoundRectangle 24"
            Padding="24,32,24,32"
            VerticalOptions="Center"
            HorizontalOptions="Center">
        <Border.Shadow>
            <Shadow Brush="Black" Offset="0,4" Radius="20" Opacity="0.4" />
        </Border.Shadow>

        <VerticalStackLayout Spacing="24" WidthRequest="320">

            <!-- Card Name Header -->
            <VerticalStackLayout Spacing="4">
                <Label Text="Add to Deck"
                       FontSize="14"
                       TextColor="{StaticResource Accent}"
                       HorizontalOptions="Center"
                       FontAttributes="Bold" />
                <Label x:Name="TitleLabel"
                       FontSize="22"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="Center"
                       TextColor="{StaticResource TextPrimary}"
                       LineBreakMode="TailTruncation" />
            </VerticalStackLayout>

            <!-- Deck Picker -->
            <VerticalStackLayout Spacing="8">
                <Label Text="Select Deck"
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="{StaticResource TextSecondary}" />
                <Border BackgroundColor="{StaticResource CardBackground}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 12"
                        Padding="8,4">
                    <Picker x:Name="DeckPicker"
                            Title="Choose a deck..."
                            FontSize="16"
                            TextColor="{StaticResource TextPrimary}"
                            TitleColor="{StaticResource TextSecondary}"
                            BackgroundColor="Transparent" />
                </Border>
            </VerticalStackLayout>

            <!-- Section Picker -->
            <VerticalStackLayout Spacing="8">
                <Label Text="Section"
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="{StaticResource TextSecondary}" />
                <Border BackgroundColor="{StaticResource CardBackground}"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 12"
                        Padding="8,4">
                    <Picker x:Name="SectionPicker"
                            FontSize="16"
                            TextColor="{StaticResource TextPrimary}"
                            BackgroundColor="Transparent">
                        <Picker.Items>
                            <x:String>Main</x:String>
                            <x:String>Sideboard</x:String>
                            <x:String>Commander</x:String>
                        </Picker.Items>
                    </Picker>
                </Border>
            </VerticalStackLayout>

            <!-- Quantity Selector -->
            <VerticalStackLayout Spacing="8">
                <Label Text="Quantity"
                       FontSize="14"
                       FontAttributes="Bold"
                       TextColor="{StaticResource TextSecondary}"
                       HorizontalTextAlignment="Center" />
                <Grid ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="24"
                      HorizontalOptions="Center"
                      WidthRequest="280">
                    <Button x:Name="MinusBtn"
                            Text="−"
                            Clicked="OnMinusClicked"
                            FontSize="28"
                            FontAttributes="Bold"
                            WidthRequest="64"
                            HeightRequest="64"
                            CornerRadius="32"
                            BackgroundColor="{StaticResource CardBackground}"
                            TextColor="{StaticResource TextPrimary}" />
                    <Label x:Name="QuantityLabel"
                           Grid.Column="1"
                           Text="1"
                           FontSize="42"
                           FontAttributes="Bold"
                           TextColor="{StaticResource TextPrimary}"
                           HorizontalTextAlignment="Center"
                           VerticalTextAlignment="Center" />
                    <Button Grid.Column="2"
                            Text="+"
                            Clicked="OnPlusClicked"
                            FontSize="28"
                            FontAttributes="Bold"
                            WidthRequest="64"
                            HeightRequest="64"
                            CornerRadius="32"
                            BackgroundColor="{StaticResource Accent}"
                            TextColor="Black" />
                </Grid>
            </VerticalStackLayout>

            <!-- Actions -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="16" Margin="0,12,0,0">
                <Button Text="Cancel"
                        Clicked="OnCancelClicked"
                        HeightRequest="56"
                        FontSize="16"
                        StyleClass="OutlinedButton" />
                <Button Grid.Column="1"
                        Text="Confirm"
                        Clicked="OnConfirmClicked"
                        HeightRequest="56"
                        FontSize="16"
                        FontAttributes="Bold"
                        StyleClass="FilledButton" />
            </Grid>

        </VerticalStackLayout>
    </Border>

</ContentPage>
