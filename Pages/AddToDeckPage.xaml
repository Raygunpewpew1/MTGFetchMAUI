<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AetherVault.Pages.AddToDeckPage"
             Title="Add to deck"
             BackgroundColor="{StaticResource Background}">

    <Grid RowDefinitions="Auto,*,Auto" Padding="20,16">

        <!-- Card name (always visible) -->
        <Border Grid.Row="0"
                Style="{StaticResource CardStyle}"
                Margin="0,0,0,16"
                Padding="16,14">
            <VerticalStackLayout Spacing="4">
                <Label Text="Adding card"
                       FontSize="12"
                       TextColor="{StaticResource TextSecondary}" />
                <Label x:Name="TitleLabel"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}"
                       LineBreakMode="TailTruncation"
                       MaxLines="2" />
            </VerticalStackLayout>
        </Border>

        <ScrollView Grid.Row="1" VerticalOptions="FillAndExpand">
            <VerticalStackLayout Spacing="20">

                <!-- No decks empty state -->
                <Border x:Name="NoDeckPanel"
                        IsVisible="False"
                        Style="{StaticResource CardStyle}"
                        Padding="20,24">
                    <VerticalStackLayout Spacing="16" HorizontalOptions="Center">
                        <Label Text="You don't have any decks yet."
                               FontSize="15"
                               TextColor="{StaticResource TextPrimary}"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center" />
                        <Button Text="Create deck"
                                Clicked="OnCreateDeckClicked"
                                BackgroundColor="{StaticResource Accent}"
                                TextColor="Black"
                                FontAttributes="Bold"
                                HeightRequest="48"
                                CornerRadius="12"
                                HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Border>

                <!-- Deck + Section + Quantity (when decks exist) -->
                <VerticalStackLayout x:Name="DeckPickerPanel" Spacing="20">

                    <Border Style="{StaticResource CardStyle}" Padding="16">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Deck"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextSecondary}" />
                            <Picker x:Name="DeckPicker"
                                    Title="Choose a deck..."
                                    FontSize="16"
                                    TextColor="{StaticResource TextPrimary}"
                                    TitleColor="{StaticResource TextSecondary}"
                                    BackgroundColor="{StaticResource Surface}"
                                    HeightRequest="48" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Padding="16">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Section"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextSecondary}" />
                            <Picker x:Name="SectionPicker"
                                    FontSize="16"
                                    TextColor="{StaticResource TextPrimary}"
                                    BackgroundColor="{StaticResource Surface}"
                                    HeightRequest="48">
                                <Picker.Items>
                                    <x:String>Main</x:String>
                                    <x:String>Sideboard</x:String>
                                    <x:String>Commander</x:String>
                                </Picker.Items>
                            </Picker>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Quantity -->
                    <Border Style="{StaticResource CardStyle}" Padding="20,16">
                        <VerticalStackLayout Spacing="16">
                            <Label Text="How many copies?"
                                   FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource TextSecondary}"
                                   HorizontalOptions="Center" />
                            <Grid ColumnDefinitions="Auto,*,Auto"
                                  ColumnSpacing="20"
                                  HorizontalOptions="Center">
                                <Button x:Name="MinusBtn"
                                        Text="−"
                                        Clicked="OnMinusClicked"
                                        FontSize="28"
                                        FontAttributes="Bold"
                                        WidthRequest="56"
                                        HeightRequest="56"
                                        CornerRadius="28"
                                        BackgroundColor="{StaticResource Surface}"
                                        TextColor="{StaticResource TextPrimary}" />
                                <Label x:Name="QuantityLabel"
                                       Grid.Column="1"
                                       Text="1"
                                       FontSize="36"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource TextPrimary}"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center"
                                       VerticalOptions="Center">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="OnQuantityTapped" />
                                    </Label.GestureRecognizers>
                                </Label>
                                <Button Grid.Column="2"
                                        Text="+"
                                        Clicked="OnPlusClicked"
                                        FontSize="28"
                                        FontAttributes="Bold"
                                        WidthRequest="56"
                                        HeightRequest="56"
                                        CornerRadius="28"
                                        BackgroundColor="{StaticResource Accent}"
                                        TextColor="Black" />
                            </Grid>
                            <Label Text="Tap the number to enter a custom amount"
                                   FontSize="11"
                                   TextColor="{StaticResource TextSecondary}"
                                   HorizontalOptions="Center" />
                            <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                                <Button Text="+1"
                                        Clicked="OnQuickAddOneClicked"
                                        HeightRequest="36"
                                        FontSize="14"
                                        WidthRequest="56"
                                        BackgroundColor="{StaticResource Surface}"
                                        TextColor="{StaticResource TextPrimary}"
                                        CornerRadius="8" />
                                <Button Text="+2"
                                        Clicked="OnQuickAddTwoClicked"
                                        HeightRequest="36"
                                        FontSize="14"
                                        WidthRequest="56"
                                        BackgroundColor="{StaticResource Surface}"
                                        TextColor="{StaticResource TextPrimary}"
                                        CornerRadius="8" />
                                <Button Text="+4"
                                        Clicked="OnQuickAddFourClicked"
                                        HeightRequest="36"
                                        FontSize="14"
                                        WidthRequest="56"
                                        BackgroundColor="{StaticResource Surface}"
                                        TextColor="{StaticResource TextPrimary}"
                                        CornerRadius="8" />
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Actions -->
        <Grid Grid.Row="2"
              ColumnDefinitions="*,*"
              ColumnSpacing="16"
              Padding="0,16,0,0">
            <Button Text="Cancel"
                    Clicked="OnCancelClicked"
                    HeightRequest="48"
                    FontSize="16"
                    BackgroundColor="{StaticResource Surface}"
                    TextColor="{StaticResource TextPrimary}"
                    CornerRadius="12"
                    StyleClass="OutlinedButton" />
            <Button x:Name="ConfirmButton"
                    Grid.Column="1"
                    Text="Add to Main"
                    Clicked="OnConfirmClicked"
                    HeightRequest="48"
                    FontSize="16"
                    FontAttributes="Bold"
                    BackgroundColor="{StaticResource Accent}"
                    TextColor="Black"
                    CornerRadius="12"
                    StyleClass="FilledButton" />
        </Grid>

    </Grid>

</ContentPage>
