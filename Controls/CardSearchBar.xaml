<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:material="http://schemas.enisn-projects.io/dotnet/maui/uraniumui/material"
             x:Class="AetherVault.Controls.CardSearchBar">
    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
        <material:TextField x:Name="SearchEntry"
                           Grid.Column="0"
                           Title="Search cards..."
                           Text="{Binding SearchText, Mode=TwoWay}"
                           ReturnCommand="{Binding SearchCommand}"
                           BackgroundColor="{StaticResource Surface}"
                           TextColor="{StaticResource TextPrimary}"
                           TitleColor="{StaticResource TextSecondary}"
                           AccentColor="{StaticResource Primary}"
                           AllowClear="True" />
        <Button x:Name="FiltersButton"
                Grid.Column="1"
                Text="{Binding FiltersButtonText}"
                Clicked="OnFiltersButtonClicked"
                IsEnabled="{Binding IsBusy, Converter={StaticResource InvertedBool}}"
                BackgroundColor="{StaticResource CardBackground}"
                HeightRequest="44"
                Padding="12,0"
                StyleClass="ElevatedButton" />
        <Button Grid.Column="2"
                Text="{Binding ViewModeButtonText}"
                Command="{Binding ToggleViewModeCommand}"
                BackgroundColor="{StaticResource CardBackground}"
                HeightRequest="44"
                Padding="12,0"
                FontSize="14"
                StyleClass="ElevatedButton"
                ToolTipProperties.Text="{Binding ViewModeToolTip}" />
    </Grid>
</ContentView>
