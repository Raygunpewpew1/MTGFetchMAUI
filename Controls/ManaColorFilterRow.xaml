<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:AetherVault.Controls"
             x:Class="AetherVault.Controls.ManaColorFilterRow"
             x:Name="Root">
    <FlexLayout BindableLayout.ItemsSource="{Binding Source={x:Reference Root}, Path=ItemsSource}"
                Wrap="Wrap"
                JustifyContent="Start"
                AlignItems="Start">
        <BindableLayout.ItemTemplate>
            <DataTemplate>
                <Grid WidthRequest="44"
                      HeightRequest="44"
                      Margin="2"
                      Opacity="0.5"
                      Scale="1">
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer
                            Command="{Binding Source={RelativeSource AncestorType={x:Type controls:ManaColorFilterRow}}, Path=ToggleColorCommand}"
                            CommandParameter="{Binding Code}" />
                    </Grid.GestureRecognizers>
                    <controls:ManaSymbolView Symbol="{Binding Code}"
                                            InputTransparent="True"
                                            WidthRequest="32"
                                            HeightRequest="32"
                                            VerticalOptions="Center"
                                            HorizontalOptions="Center" />
                    <Grid.Triggers>
                        <DataTrigger TargetType="Grid" Binding="{Binding IsSelected}" Value="True">
                            <DataTrigger.Setters>
                                <Setter Property="Opacity" Value="1" />
                                <Setter Property="Scale" Value="1.08" />
                            </DataTrigger.Setters>
                        </DataTrigger>
                    </Grid.Triggers>
                </Grid>
            </DataTemplate>
        </BindableLayout.ItemTemplate>
    </FlexLayout>
</ContentView>
