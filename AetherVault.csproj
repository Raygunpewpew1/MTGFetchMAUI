<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<TargetFrameworks>net10.0-android</TargetFrameworks>
		<OutputType>Exe</OutputType>
		<RootNamespace>AetherVault</RootNamespace>
		<UseMaui>true</UseMaui>
		<SingleProject>true</SingleProject>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<LangVersion>preview</LangVersion>
		<EnablePreviewFeatures>true</EnablePreviewFeatures>
		<MauiXamlInflator>SourceGen</MauiXamlInflator>
		<SkipValidateMauiImplicitPackageReferences>true</SkipValidateMauiImplicitPackageReferences>
		<UseNativeAOTRuntime>false</UseNativeAOTRuntime>
		

		<EnableNETAnalyzers>false</EnableNETAnalyzers>
		<ApplicationTitle>AetherVault</ApplicationTitle>

		<ApplicationId>com.aethervault.mobile</ApplicationId>

		<ApplicationDisplayVersion>2</ApplicationDisplayVersion>
		<ApplicationVersion>$([System.DateTimeOffset]::UtcNow.ToUnixTimeSeconds())</ApplicationVersion>

		<SupportedOSPlatformVersion Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'android'">21.0</SupportedOSPlatformVersion>

		<GenerateAssemblyInfo>false</GenerateAssemblyInfo>
		<GenerateTargetFrameworkAttribute>false</GenerateTargetFrameworkAttribute>
		<SignAssembly>False</SignAssembly>

		<GeneratePackageOnBuild>False</GeneratePackageOnBuild>

		<Description>magic the gathering stuff</Description>

		<PackageProjectUrl></PackageProjectUrl>

		<RepositoryUrl>https://github.com/Raygunpewpew1/AetherVault</RepositoryUrl>

		<DefaultLanguage>en</DefaultLanguage>
	</PropertyGroup>

	<PropertyGroup Condition="'$(Configuration)|$(TargetFramework)|$(Platform)'=='Debug|net10.0-android|AnyCPU'">
		<EmbedAssembliesIntoApk>True</EmbedAssembliesIntoApk>
		<AndroidKeyStore>False</AndroidKeyStore>
		<ApplicationIdGuid></ApplicationIdGuid>
	</PropertyGroup>

	<PropertyGroup Condition="'$(Configuration)|$(TargetFramework)|$(Platform)'=='Release|net10.0-android|AnyCPU'">
	  <AndroidKeyStore>False</AndroidKeyStore>
	  <ApplicationIdGuid></ApplicationIdGuid>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="AppoMobi.Maui.Gestures" Version="1.11.9.2" />
		<PackageReference Include="CommunityToolkit.Maui" Version="14.0.1" />
		<PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.0" />
		<PackageReference Include="Microsoft.Maui.Controls" Version="10.0.41" />
		<PackageReference Include="Microsoft.Data.Sqlite" Version="10.0.3" />
		<PackageReference Include="Dapper" Version="2.1.66" />
		<PackageReference Include="SkiaSharp" Version="3.119.2" />
		<PackageReference Include="SkiaSharp.Views.Maui.Controls" Version="3.119.2" />
		<PackageReference Include="Svg.Skia" Version="3.4.1" />
		<PackageReference Include="UraniumUI.Icons.FontAwesome" Version="2.14.0" />
		<PackageReference Include="UraniumUI.Material" Version="2.14.0" />
		<PackageReference Include="xunit.abstractions" Version="2.0.3" />
	<PackageReference Include="CsvHelper" Version="33.1.0" />
	</ItemGroup>

	<ItemGroup Condition="$([MSBuild]::GetTargetPlatformIdentifier('$(TargetFramework)')) == 'android'">
		<PackageReference Include="Plugin.Maui.OCR" Version="1.1.1" />
	</ItemGroup>

	<ItemGroup>
		<MauiIcon Include="Resources\AppIcon\appicon.svg" ForegroundFile="Resources\AppIcon\appiconfg.svg" Color="#0f0028" />
		<MauiSplashScreen Include="Resources\Splash\splash.svg" Color="#0D0B12" BaseSize="512,512" />
		<MauiImage Include="Resources\Images\*" />
	</ItemGroup>

	<ItemGroup>
		<EmbeddedResource Include="Resources\Images\mana_*.svg" />
		<EmbeddedResource Include="Assets\SVGSets\*.svg" />
	</ItemGroup>

	<ItemGroup>
		<Compile Remove="AetherVault.Tests\**" />	
		<EmbeddedResource Remove="AetherVault.Tests\**" />
		<None Remove="AetherVault.Tests\**" />
		<None Remove="BENCHMARK_RESULTS.md" />
		<None Remove="MTGFetchMAUI.csproj.Backup.tmp" />
		<None Remove="Resources\Splash\_splash.svg" />
	</ItemGroup>

</Project>